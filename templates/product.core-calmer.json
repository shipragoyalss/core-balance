{"wrapper":"div.template-product-wrapper","sections":{"product-information":{"type":"product-information","blocks":{"selling_features":{"type":"selling_features","settings":{"show_rating":false}},"text":{"type":"text","settings":{"show_vendor":false,"vendor_link":"","short_description":"","font_size":100}},"title":{"type":"title","settings":{"font_size":100}},"price":{"type":"price","settings":{"font_size":100}},"countdown":{"type":"countdown","settings":{"countdown_title":"Sales ends in:","font_size":100,"background":"alt-sale"}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button","color_swatch_type":"none","color_swatch_shape":"circle","swatch_size":36}},"buy_buttons":{"type":"buy_buttons","settings":{"show_inventory_notification":true,"quantity_threshold":5,"notification_message":"New - no sales tax","show_gift_card_recipient":false,"show_dynamic_checkout":true,"show_quantity_selector":true}}},"block_order":["selling_features","text","title","price","countdown","variant_picker","buy_buttons"],"settings":{"show_breadcrumbs":false,"enable_all_images":false,"enable_image_zoom":false,"padding_top":0,"padding_bottom":40}},"product-content":{"type":"product-content","blocks":{"description":{"type":"description","settings":{"padding_top":0,"padding_bottom":50}},"8ede0f35-6469-4359-b80b-e71bf218d10b":{"type":"product_notes","settings":{"collapsible_content":true,"notes_title":"Ingredients","notes_text":"<p>Corn Oil, Taurine, Magnesium Citrate, Magnesium Sulfate, Sodium Aluminosilicate, Thiamine Mononitrate, Inositol, Calcium Silicate, Pyridoxine Hydrochloride, Natural & Artificial Flavor, Soy Lecithin, Polysorbate 80, Sorbic Acid (a preservative).<\/p>","page":"","padding_top":0,"padding_bottom":0}},"1ccf04ef-b1dd-41fb-90c9-15876644deca":{"type":"product_notes","settings":{"collapsible_content":true,"notes_title":"Supplementing Instructions","notes_text":"<p><strong>PASTE<\/strong><\/p><p>Administer contents of the syringe directly on the horse's tongue, preferably the back of the tongue. Administer carefully to assure swallowing.<\/p><p><strong>Performance & Training*: <\/strong>Dispense one full syringe 1.5-3 hours prior to training or competition.<\/p><p><strong>Travel*: <\/strong>dispense one full syringe 2 hours prior to loading; one full syringe may be given every 8 hours if transport is long.<\/p><p>*May be altered depending on the individual horse.<\/p><p><\/p><p><\/p><p><strong>POWDER<\/strong><\/p><p>Give ½ to 1 scoop twice daily as needed for training, trailering, or competition.  <\/p><p>Scoop holds 1 ounce.    <\/p><p>May take up to 8 hours to see effect in the horse. <\/p><p><\/p>","page":"","padding_top":0,"padding_bottom":0}},"complementary":{"type":"complementary","settings":{"block_heading":"Pairs well with","product_list_limit":10,"picker_type":"button","color_swatch_type":"none","color_swatch_shape":"circle","swatch_size":36,"padding_top":0,"padding_bottom":50}}},"block_order":["description","8ede0f35-6469-4359-b80b-e71bf218d10b","1ccf04ef-b1dd-41fb-90c9-15876644deca","complementary"],"settings":{"padding_top":20,"padding_bottom":0}},"171442617833e7d99a":{"type":"apps","blocks":{"judge_me_reviews_review_widget_RtLpjc":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/review_widget\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{"review_data":"sample_data","max_width":1200,"show_shop_reviews":false,"empty_state":"empty_widget"}}},"block_order":["judge_me_reviews_review_widget_RtLpjc"],"settings":{"include_margins":true}},"product-recommendations":{"type":"product-recommendations","settings":{"heading":"You might also like","columns":3,"padding_top":44,"padding_bottom":44}}},"order":["product-information","product-content","171442617833e7d99a","product-recommendations"]}