{{ 'section-feature-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign icon_style = settings.icons_style
  assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo, youtube' | split: ','
%}

<div class="section-{{ section.id }}-padding">
  <div class="icon-column-section">
    <div class="page-width">
      <ul class="icon-column-section__list icon-column-section__list--{{ section.settings.columns }}">
        {% for block in section.blocks %}
          {%- assign animation_delay = animation_delay | plus: 0.08 -%}
          <li class="scroll-animate fade-in-up" style="animation-delay: {{ animation_delay }}s;" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="card-box card-box--vertical {{ section.settings.background }}">
            {%- else -%}
              <div class="card-box card-box--vertical {{ section.settings.background }}">
            {%- endif -%}
              {%- if block.settings.feature_image != blank or block.settings.video != blank -%}
                {%- capture "aspect_ratio" -%}
                  {% if block.settings.video != blank %}
                    {{ block.settings.video.aspect_ratio }}
                  {% else %}
                    {{ block.settings.feature_image.aspect_ratio }}
                  {% endif %}
                {%- endcapture -%}
                <div class="card-box__image">
                  {% assign sizes = "(max-width: 768px) calc(100vw - 1.5rem), (max-width: 1024px) calc((100vw - 1.5rem) / 2), (max-width: 1520px) calc((100vw - 5.5rem) / 3), calc((1520px - 5.5rem) / 3)" %}
                  {% if block.settings.video != blank %}
                    <video-content>
                  {% endif %}
                    <div class="media media--transparent media--{{ section.settings.image_ratio }}"
                      {% if section.settings.image_ratio == 'adapt' %} style="padding-bottom: {{ 1 | divided_by: aspect_ratio | times: 100 }}%;"{% endif %}>
                      {% if block.settings.video != blank %}
                        {%- capture "video_classes" -%}media__video{% if block.settings.autoplay_video %} media__video--autoplay{% endif %}{%- endcapture -%}
                        {% liquid
                          if block.settings.autoplay_video
                            assign playsinline = true
                            assign loop = true
                            assign autoplay = true
                            assign muted = true
                            assign controls = false
                          else
                            assign playsinline = false
                            assign loop = false
                            assign autoplay = false
                            assign muted = false
                            assign controls = true
                          endif
                        %}
                        {{ block.settings.video | video_tag:
                          image_size: '1200x',
                          class: video_classes,
                          playsinline: playsinline,
                          loop: loop,
                          autoplay: autoplay,
                          muted: muted,
                          controls: controls
                        }}
                      {% elsif block.settings.feature_image != blank %}
                        {% assign image_height =  block.settings.feature_image.width | divided_by: block.settings.feature_image.aspect_ratio %}

                        {{ block.settings.feature_image | image_url: width: 1200 | image_tag:
                          loading: 'lazy',
                          class: 'lazyload',
                          width: block.settings.feature_image.width,
                          height: image_height,
                          sizes: sizes,
                          widths: '200, 300, 400, 550, 720, 990, 1200',
                          alt: block.settings.feature_image.alt | escape
                        }}
                      {% endif %}
                    </div>
                    {% if block.settings.video != blank and block.settings.autoplay_video == false %}
                      <div class="media__video-overlay">
                        <div class="media__video-overlay__img">
                          <div class="media media--transparent media--{{ section.settings.image_ratio }}"
                            {% if section.settings.image_ratio == 'adapt' %} style="padding-bottom: {{ 1 | divided_by: aspect_ratio | times: 100 }}%;"{% endif %}>
                            {% if block.settings.image != blank %}
                              {%- assign image_height = block.settings.image.width
                                | divided_by: block.settings.image.aspect_ratio
                              -%}
                              {{
                                block.settings.image
                                | image_url: width: 1200
                                | image_tag:
                                  loading: 'lazy',
                                  width: block.settings.image.width,
                                  height: image_height,
                                  class: 'motion-reduce media__transparent',
                                  sizes: sizes,
                                  widths: '200, 300, 400, 550, 720, 990, 1200',
                                  alt: block.settings.image.alt
                                | escape
                              }}
                            {% elsif block.settings.video != blank %}
                              {%- assign image_height = block.settings.video.preview_image.width
                                | divided_by: block.settings.video.preview_image.aspect_ratio
                              -%}
                              {{
                                block.settings.video.preview_image
                                | image_url: width: 1200
                                | image_tag:
                                  loading: 'lazy',
                                  width: block.settings.video.preview_image.width,
                                  height: image_height,
                                  class: 'motion-reduce media__transparent',
                                  sizes: sizes,
                                  widths: '200, 300, 400, 550, 720, 990, 1200',
                                  alt: block.settings.video.preview_image.alt
                                | escape
                              }}
                            {% else %}
                              {{ 'lifestyle-1' | placeholder_svg_tag: 'media__transparent' }}
                            {% endif %}
                          </div>
                        </div>
                        <div class="media__overlay__inner">
                          <a href="#" class="media__play" aria-label="Play video">
                            <i class="icon icon-play {{ icon_style }} fa-circle-play"></i>
                          </a>
                        </div>
                      </div>
                    {% endif %}
                  {% if block.settings.video != blank %}
                    </video-content>
                  {% endif %}
                </div>
              {%- endif -%}
              <div class="card-box__content text-{{ section.settings.align_text }}" style="--font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }}; --icon-scale: {{ section.settings.icon_size | divided_by: 100.0 }};">
                {% if block.settings.feature_custom_icon != blank %}
                  <img src="{{ block.settings.feature_custom_icon | img_url: '220x' }}" alt="{{ block.settings.feature_title }}" loading="lazy" width="110" height="auto">
                {% elsif block.settings.feature_icon != 'none' %}
                  {% assign brand_icon = brand_icons | where: block.settings.feature_icon | first %}
                  {% if brand_icon %}
                    {% assign icon_style = 'fa-brands' %}
                  {% endif %}
                  <i class="icon {{ icon_style }} fa-{{ block.settings.feature_icon }}"></i>
                {% endif %}
                {% if block.settings.feature_title != blank %}
                  <h2 class="h5">
                    {{ block.settings.feature_title }}
                  </h2>
                {% endif %}
                {% if block.settings.feature_text != blank %}
                  <div class="card-box__text">{{ block.settings.feature_text }}</div>
                {% endif %}

                {% if block.settings.button_label != blank %}
                  <div class="btn btn--small{% if section.settings.button_style == 'ghost' %} btn--secondary{% endif %}">
                    {{- block.settings.button_label | escape -}}
                  </div>
                {% endif %}
              </div>
            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.feature-cards.name",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.feature-cards.settings.image_ratio.label",
      "options": [
        {
          "value": "landscape",
          "label": "3:2"
        },
        {
          "value": "portrait",
          "label": "4:5"
        },
        {
          "value": "square",
          "label": "1:1"
        },
        {
          "value": "adapt",
          "label": "Adapt to media"
        }
      ],
      "default": "landscape"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.feature-cards.settings.columns.label",
      "default": 3,
      "min": 2,
      "max": 4,
      "step": 1
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:sections.all.font_size.label",
      "default": 100,
      "min": 80,
      "max": 120,
      "unit": "%",
      "step": 1
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "t:sections.feature-cards.settings.icon_size.label",
      "default": 100,
      "min": 30,
      "max": 230,
      "unit": "%",
      "step": 2
    },
    {
      "type": "select",
      "id": "align_text",
      "label": "t:sections.feature-columns.settings.align_text.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "t:sections.feature-columns.settings.align_text.option__1"
        },
        {
          "value": "center",
          "label": "t:sections.feature-columns.settings.align_text.option__2"
        }
      ]
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.feature-cards.settings.button_style.label",
      "default": "ghost",
      "options": [
        {
          "value": "solid",
          "label": "t:sections.feature-cards.settings.button_style.options__1.label"
        },
        {
          "value": "ghost",
          "label": "t:sections.feature-cards.settings.button_style.options__2.label"
