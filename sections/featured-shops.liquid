{{ 'section-featured-shops.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign icon_style = settings.icons_style
  assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo, youtube' | split: ','
%}

<div class="section-{{ section.id }}-padding">
  <div class="featured-shops page-width" style="--font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }};">
    <h2 class="h1 {{ section.settings.color_text }} scroll-animate fade-in">{{ section.settings.title }}</h2>
    <ul style="--size-scale: {{ section.settings.circle_size | divided_by: 100.0 }};">
      {% for block in section.blocks %}
        {%- assign animation_delay = animation_delay | plus: 0.08 -%}
        <li class="featured-shops__item {{ section.settings.font_type }}" style="--icon-scale: {{ block.settings.icon_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a class="featured-shops__item-wrap" href="{{ block.settings.link }}">
          {%- else -%}
            <div class="featured-shops__item-wrap">
          {%- endif -%}
            <div class="shop-bubble {{ section.settings.background }} scroll-animate zoom-in-fade-in" style="animation-delay: {{ animation_delay }}s;">
              <div class="shop-bubble__wrap">
                {% if block.settings.image != blank %}
                  <div class="shop-bubble__image media media--transparent">
                    {%- assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio -%}
                    {%- capture sizes -%}(min-width: 1520px) 120, (min-width: 768px) 100, calc(100vw / 2){%- endcapture -%}
                    {{ block.settings.image | image_url: width: 720 | image_tag:
                      loading: 'lazy',
                      width: block.settings.image.width,
                      height: image_height,
                      class: 'motion-reduce media__transparent',
                      sizes: sizes,
                      widths: '120, 330, 533, 720',
                      alt: block.settings.image.alt | escape
                    }}
                  </div>
                {% elsif block.settings.icon != 'none'  %}
                  <div class="shop-bubble__icon">
                    {% assign brand_icon = brand_icons | where: block.settings.icon | first %}
                    {% if brand_icon %}
                      {% assign icon_style = 'fa-brands' %}
                    {% endif %}
                    <i class="icon {{ icon_style }} fa-{{ block.settings.icon }}"></i>
                  </div>
                {% else %}
                  <div class="media media--placeholder media--square">
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>
            </div>
            <h3 class="{{ section.settings.color_text }} scroll-animate fade-in">{{ block.settings.slide_title }}</h3>
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

