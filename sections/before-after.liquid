{{ 'section-before-after.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% assign icon_style = settings.icons_style %}

<div class="section-{{ section.id }}-padding">
  <div class="before-after-section page-width" style="--font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }};">
    <div class="{{ section.settings.color_text }}">
      {% if section.settings.title != blank %}
        <h2 class="h1 scroll-animate fade-in-up" style="animation-delay: 0.07s;">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="scroll-animate fade-in-up" style="animation-delay: 0.14s;">{{ section.settings.description }}</p>
      {% endif %}
      {%- if section.settings.button_label != blank -%}
        <a
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
          class="btn btn--secondary scroll-animate fade-in-up"
          style="animation-delay: 0.21s;"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
    <div class="before-after-content scroll-animate fade-in">
      <div class="before-after__img-before">
        {%- capture sizes -%}(min-width: 1520px) 1800px, (min-width: 1024px) calc(100vw - 176px), (min-width: 768px) calc(100vw - 48px){%- endcapture -%}
        {% if section.settings.video_before != blank %}
          <video-content>
            <div class="media media--landscape">
              {%- capture "video_classes" -%}media__video{% if section.settings.autoplay_video_before %} media__video--autoplay{% endif %}{%- endcapture -%}
              {% liquid
                assign playsinline = true
                assign loop = true
                assign autoplay = true
                assign muted = true
                assign controls = false
              %}
              {{ section.settings.video_before | video_tag:
                image_size: '1800x',
                class: video_classes,
                playsinline: playsinline,
                loop: loop,
                autoplay: autoplay,
                muted: muted,
                controls: controls
              }}
            </div>
          </video-content>
        {% else %}
          <div class="media media--landscape">
            {% if section.settings.image_before != blank %}
              {%- assign image_height = section.settings.image_before.width | divided_by: section.settings.image_before.aspect_ratio -%}
              {{ section.settings.image_before
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  width: section.settings.image_before.width,
                  height: image_height,
                  class: 'media__transparent',
                  sizes: sizes,
                  widths: '165, 375, 750, 900, 1100, 1500, 1780, 1800',
                  alt: section.settings.image_before.alt
                | escape
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'media__transparent placeholder-svg' }}
            {% endif %}
          </div>
        {% endif %}
        <div class="before-after-content__arrow">
          <i class="icon {{ icon_style }} fa-chevron-left fa-swap-opacity"></i>

          <i class="icon {{ icon_style }} fa-chevron-right fa-swap-opacity"></i>
        </div>
      </div>
      <div class="before-after__img-after">
        {% if section.settings.video_after != blank %}
          <video-content>
            <div class="media media--landscape">
              {%- capture "video_classes" -%}media__video{% if section.settings.autoplay_video_after %} media__video--autoplay{% endif %}{%- endcapture -%}
              {% liquid
                assign playsinline = true
                assign loop = true
                assign autoplay = true
                assign muted = true
                assign controls = false
              %}
              {{ section.settings.video_after | video_tag:
                image_size: '1800x',
                class: video_classes,
                playsinline: playsinline,
                loop: loop,
                autoplay: autoplay,
                muted: muted,
                controls: controls
              }}
            </div>
          </video-content>
        {% else %}
          <div class="media media--landscape">
            {% if section.settings.image_after != blank %}
              {%- assign image_height = section.settings.image_after.width | divided_by: section.settings.image_after.aspect_ratio -%}
              {%- capture sizes -%}(min-width: 1520px) 1800px, (min-width: 1024px) calc(100vw - 176px), (min-width: 768px) calc(100vw - 48px){%- endcapture -%}
              {{ section.settings.image_after
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  width: section.settings.image_after.width,
                  height: image_height,
                  class: 'media__transparent',
                  sizes: sizes,
                  widths: '165, 375, 750, 900, 1100, 1500, 1780, 1800',
                  alt: section.settings.image_after.alt
                | escape
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'media__transparent placeholder-svg' }}
            {% endif %}
          </div>
        {% endif %}
      </div>
      <div class="before-after__slider-wrap">
        <split-slider class="before-after__slider">
          <label class="visually-hidden" for="slider">{{ 'sections.before-and-after.label_range' | t }}</label>
          <input type="range" min="0" max="100" value="50" id="slider">
        </split-slider>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.before-and-after.name",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.before-and-after.settings.heading.label",
      "default": "Before & after"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.before-and-after.settings.description.label",
      "default": "Add a product feature or answer a common questions about your products."
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:sections.all.font_size.label",
      "default": 100,
      "min": 80,
      "max": 120,
      "unit": "%",
      "step": 1
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.before-and-after.settings.button_label.label",
      "default": "Optional Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.before-and-after.settings.button_link.label"
    },
    {
      "type": "select",
      "id": "color_text",
      "label": "t:sections.all.colors.label_text",
      "options": [
        {
          "value": "primary-text-1",
          "label": "t:sections.all.colors.primary_text_1.label"
        },
        {
          "value": "secondary-text-1",
          "label": "t:sections.all.colors.secondary_text_1.label"
        },
        {
          "value": "primary-text-2",
          "label": "t:sections.all.colors.primary_text_2.label"
        },
        {
          "value": "secondary-text-2",
          "label": "t:sections.all.colors.secondary_text_2.label"
        },
        {
          "value": "primary-text-3",
          "label": "t:sections.all.colors.primary_text_3.label"
        },
        {
          "value": "secondary-text-3",
          "label": "t:sections.all.colors.secondary_text_3.label"
        },
        {
          "value": "primary-text-4",
          "label": "t:sections.all.colors.primary_text_4.label"
        },
        {
          "value": "secondary-text-4",
          "label": "t:sections.all.colors.secondary_text_4.label"
        },
        {
          "value": "primary-text-5",
          "label": "t:sections.all.colors.primary_text_5.label"
        },
        {
          "value": "secondary-text-5",
          "label": "t:sections.all.colors.secondary_text_5.label"
        },
        {
          "value": "sale-text",
          "label": "t:sections.all.colors.sale_text.label"
        }
      ],
      "default": "primary-text-1"
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "t:sections.before-and-after.settings.image_before.label",
      "info": "t:sections.before-and-after.settings.image_before.info"
    },
    {
      "type": "video",
      "id": "video_before",
      "label": "t:sections.media-with-text.settings.video.label",
      "info": "t:sections.media-with-text.settings.video.info"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "t:sections.before-and-after.settings.image_after.label",
      "info": "t:sections.before-and-after.settings.image_after.info"
    },
    {
      "type": "video",
      "id": "video_after",
      "label": "t:sections.media-with-text.settings.video.label",
      "info": "t:sections.media-with-text.settings.video.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing.section_spacing_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_top",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_bottom",
      "default": 44
    }
  ],
  "presets": [
    {
      "name": "t:sections.before-and-after.name"
    }
  ]
}
{% endschema %}