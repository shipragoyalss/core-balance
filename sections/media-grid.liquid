{{ 'section-media-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% assign icon_style = settings.icons_style %}

<div class="section-{{ section.id }}-padding">
  <div class="section-image-grid page-width">
    <div class="image-grid__header {{ section.settings.color_text }} scroll-animate fade-in">
      <div style="--font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }};">
        {% if section.settings.title != blank %}
          <h2 class="h0">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="rte rte-setting">
            <p>{{ section.settings.text }}</p>
          </div>
        {% endif %}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
          class="btn btn--secondary"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
    <div class="image-grid__content">
      <div class="image-grid__content-grid" style="--font-section-scale: {{ section.settings.font_image_size | divided_by: 100.0 }}; --row-media-height: {{ section.settings.row_height }}px;">
        {% liquid
          assign text_enable = true
          if section.settings.title_on_hover and section.settings.description_on_hover
          assign text_enable = false
          endif
        %}
        {%- for block in section.blocks -%}
          {%- assign animation_delay = animation_delay | plus: 0.08 -%}
          <div class="image-grid__item scroll-animate zoom-out-fade-in" style="animation-delay: {{ animation_delay }}s; --item-grid-column-span: {{ block.settings.item_width }}; --item-grid-row-span: {{ block.settings.item_height }};" {{ block.shopify_attributes }}>
            <div class="image-grid__item-card{% if block.settings.autoplay_video == false %} image-grid__item-card--disable-animation{% endif %}">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="image-grid__item-card__inner">
              {%- else -%}
                <div class="image-grid__item-card__inner">
              {%- endif -%}
                <div class="image-grid__media">
                  {%- capture sizes -%}(min-width: 1520px) {{ 1520 | minus: 440 }}px, (min-width: 1024px) calc(58vw - 176px), (min-width: 768px) calc(58vw - 48px), calc(100vw - 48px){%- endcapture -%}
                  {% if block.settings.video != blank %}
                    <video-content>
                  {% endif %}
                    <div class="media media--transparent{% unless text_enable %} media--disable-scrim{% endunless %}" {%- if block.settings.show_scrim -%} style="--scrim-lightness: {{ block.settings.scrim_lightness }}, {{ block.settings.scrim_lightness }}, {{ block.settings.scrim_lightness }}"{%- endif -%}>
                      {% if block.settings.video != blank %}
                        {%- capture "video_classes" -%}media__video{% if block.settings.autoplay_video %} media__video--autoplay{% endif %}{%- endcapture -%}
                        {% liquid
                          if block.settings.autoplay_video
                            assign playsinline = true
                            assign loop = true
                            assign autoplay = true
                            assign muted = true
                            assign controls = false
                          else
                            assign playsinline = false
                            assign loop = false
                            assign autoplay = false
                            assign muted = false
                            assign controls = true
                          endif
                        %}
                        {{ block.settings.video | video_tag:
                          image_size: '940x',
                          class: video_classes,
                          playsinline: playsinline,
                          loop: loop,
                          autoplay: autoplay,
                          muted: muted,
                          controls: controls
                        }}
                      {% elsif block.settings.image != blank %}
                        {%- assign image_height = block.settings.image.width
                          | divided_by: block.settings.image.aspect_ratio
                        -%}
                        {{
                          block.settings.image
                          | image_url: width: 940
                          | image_tag:
                            loading: 'lazy',
                            width: block.settings.image.width,
                            height: image_height,
                            class: 'motion-reduce media__transparent',
                            sizes: sizes,
                            widths: '165, 360, 533, 720, 940',
                            alt: block.settings.image.alt
                          | escape
                        }}
                      {% else %}
                        {{ 'image' | placeholder_svg_tag: 'media__transparent placeholder-svg' }}
                      {% endif %}
                    </div>
                    {% if block.settings.video != blank and block.settings.autoplay_video == false %}
                      <div class="media__video-overlay">
                        <div class="media__video-overlay__img">
                          <div class="media media--transparent">
                            {% if block.settings.image != blank %}
                              {%- assign image_height = block.settings.image.width
                                | divided_by: block.settings.image.aspect_ratio
                              -%}
                              {{
                                block.settings.image
                                | image_url: width: 940
                                | image_tag:
                                  loading: 'lazy',
                                  width: block.settings.image.width,
                                  height: image_height,
                                  class: 'motion-reduce media__transparent',
                                  sizes: sizes,
                                  widths: '165, 210, 330, 533, 720, 940',
                                  alt: block.settings.image.alt
                                | escape
                              }}
                            {% elsif block.settings.video != blank %}
                              {%- assign image_height = block.settings.video.preview_image.width
                                | divided_by: block.settings.video.preview_image.aspect_ratio
                              -%}
                              {{
                                block.settings.video.preview_image
                                | image_url: width: 940
                                | image_tag:
                                  loading: 'lazy',
                                  width: block.settings.video.preview_image.width,
                                  height: image_height,
                                  class: 'motion-reduce media__transparent',
                                  sizes: sizes,
                                  widths: '165, 210, 330, 533, 720, 940',
                                  alt: block.settings.video.preview_image.alt
                                | escape
                              }}
                            {% else %}
                              {{ 'lifestyle-1' | placeholder_svg_tag: 'media__transparent' }}
                            {% endif %}
                          </div>
                        </div>
                        <div class="media__overlay__inner">
                          <a href="#" class="media__play" aria-label="Play video">
                            <i class="icon icon-play {{ icon_style }} fa-circle-play"></i>
                          </a>
                        </div>
                      </div>
                    {% endif %}
                  {% if block.settings.video != blank %}
                    </video-content>
                  {% endif %}
                </div>
                <div class="image-grid__item-text image-grid__item-text--{{ section.settings.text_position }} {{ section.settings.color_image_text }}">
                  <h3 class="image-grid__item-title{% if section.settings.title_on_hover %} image-grid__item-title--animate{% endif %}">{{ block.settings.title }}</h3>
                  <div class="image-grid__item-description{% if section.settings.description_on_hover %} image-grid__item-description--animate{% endif %}">
                    <p>{{ block.settings.text }}</p>
                  </div>
                </div>
              {%- if block.settings.link != blank -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor-%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
