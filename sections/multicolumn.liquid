{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign icon_style = settings.icons_style
  assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo, youtube' | split: ','
  assign animation_delay = 0.00
%}

{%- capture background_class -%}
  {%- if section.settings.gradient_background != blank -%}
    multicolumn-section--taller
  {%- endif -%}
{%- endcapture -%}
<div class="{{section.settings.class}} section-{{ section.id }}-padding">
  <div class="multicolumn-section {{ section.settings.background }} {{ section.settings.custom_background }} {{ background_class }}" style="{% if section.settings.gradient_background != blank %} background: {{ section.settings.gradient_background }};{% elsif section.settings.custom_background == 'watercolor' %} background: none;{% endif %}">
    <div class="page-width">
          {% if section.settings.heading != blank or section.settings.description != blank %}
          <div class="multicolum-title">
            {% if section.settings.heading != blank %}
              <h2>{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.description != blank %}
              <p>{{ section.settings.description }}</p>
            {% endif %}
          </div>
      {% endif %}
      <ul class="multicolumn__list multicolumn__list--{{ section.settings.columns }}">
        {%- for block in section.blocks -%}
          {%- assign animation_delay = animation_delay | plus: 0.08 -%}
          <li class="scroll-animate fade-in-up" style="animation-delay: {{ animation_delay }}s;">
            {% if block.settings.link != blank %}
              <a class="multicolumn__item-anchor container-anchor" href="{{ block.settings.link }}">
            {% endif %}
              <div class="multicolumn__item {% if section.settings.icon_align == 'center' %} multicolumn__item--center{% endif %}{% if section.settings.custom_background == 'watercolor' %} multicolumn__item--background{% endif %}" {{ block.shopify_attributes }}>
                <div class="multicolumn__img" style="--icon-scale: {{ section.settings.icon_size | divided_by: 100.0 }};{% if section.settings.gradient_background != blank %} color: {{ section.settings.gradient_text_color }};{% endif %}">
                  {%- if block.settings.custom_image != blank -%}
                    {{ block.settings.custom_image | img_url: '140x', scale: 2 | img_tag: block.settings.custom_image.alt }}
                  {% elsif block.settings.icon != 'none' %}
                    {% assign brand_icon = brand_icons | where: block.settings.icon | first %}
                    {% if brand_icon %}
                      {% assign icon_style = 'fa-brands' %}
                    {% endif %}
                    <i class="icon {{ icon_style }} fa-{{ block.settings.icon }}"></i>
                  {%- endif -%}
                </div>
                <div class="multicolumn__text multicolumn__text--{{ section.settings.text_align }}" style="--font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }};">
                  {%- if block.settings.title != blank -%}
                    <h4 class="h4" {% if section.settings.gradient_background != blank %}style="color: {{ section.settings.gradient_text_color }};"{% endif %}>{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="rte" {% if section.settings.gradient_background != blank %}style="color: {{ section.settings.gradient_text_color }};"{% endif %}>
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

