{{ 'section-hero-video.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% if section.settings.transparent_header %}
    #shopify-section-{{ section.id }} {
      margin-block-start: calc(-1 * var(--header-height) * var(--section-is-first));
    }

    .hero-video__text-content {
      padding-top: var(--header-height);
    }
  {% endif %}

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign mobile_height = section.settings.image_height
  assign image_aspect_ratio = 1.7777777778

  if section.settings.video != blank
    assign image_aspect_ratio = section.settings.video.aspect_ratio
  else
    assign image_aspect_ratio = 1.7777777778
  endif
%}

<div class="{{ section.settings.class }} section-{{ section.id }}-padding" {% if section.settings.transparent_header %}allow-transparent-header{% endif %}>
  <section-animate class="hero-video{% if section.settings.video == null and section.settings.video_url != null %} hero-video--iframe{% endif %}" data-section-id="{{ section.id }}" style="--image-aspect-ratio: {{ image_aspect_ratio }}; --mobile-min-height: {{ mobile_height }}vh;" {% if section.settings.autoplay_video %}data-autoplay-video=true{% endif %}>
    <div class="hero-video__inner">
      <div class="hero-video__text-content hero-video__text-content--{{ section.settings.content_aligment }}" style="max-width: {{ section.settings.container_width }}px; --vertical-position: {{ section.settings.vertical_position }}%; --horizontal-position: {{ section.settings.horizontal_position }}%;">
        <div class="page-width">
        {%- for block in section.blocks -%}
          {% case block.type %}
          {%- when 'heading' -%}
            <div class="hero-video__text" style="--font-color: {{ block.settings.font_color }};--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
              <h1 class="h0">
                {{ block.settings.heading }}
              </h1>
              {%- if block.settings.subheading != blank -%}
                <p>{{ block.settings.subheading }}</p>
              {%- endif -%}
            </div>
            {%- when 'text' -%}
            <div 
              class="hero-video__description"
              style="
                color: {{ block.settings.color }};
                font-size: {{ block.settings.font_size }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div class="hero-video__btn-container">
              {% for i in (1..2) %}
                {% capture button_label %}button_label_{{i}}{% endcapture %}
                {% capture button_link %}button_link_{{i}}{% endcapture %}
                {% if block.settings[button_label] != blank %}
                  <div class="hero-video__btn" style="--color-button: {{ block.settings.button_color.red }}, {{ block.settings.button_color.green }}, {{ block.settings.button_color.blue }}; --color-button-text: {{ block.settings.font_button_color.red }}, {{ block.settings.font_button_color.green }}, {{ block.settings.font_button_color.blue }}; --font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
                    <a href="{{ block.settings[button_link] }}" target="_self" class="btn{% unless forloop.first %} btn--secondary{% endunless %}">{{ block.settings[button_label] }}</a>
                  </div>
                {% endif %}
              {%- endfor -%}
            </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
      </div>
      <div class="hero-video__imagery">
        <div class="hero-video__imagery-inner hero-video__imagery-inner--{{ section.settings.video_animation }}">
          <div>
            <div class="hero-video__video" {%- if section.settings.show_scrim -%} style="--scrim-lightness: {{ section.settings.scrim_lightness }}, {{ section.settings.scrim_lightness }}, {{ section.settings.scrim_lightness }}"{%- endif -%}>
              <div class="media media--transparent media-position--{{ section.settings.media_position }}">
                {%- if section.settings.video != blank or section.settings.video_url != blank -%}

  <!-- VIDEO -->
  <div class="hero__media no-js-hidden">
    {%- liquid
      assign video_id = section.settings.video.id | default: section.settings.video_url.id
      assign loop = '&autoplay=0'
      if section.settings.autoplay_video
        assign loop = '&mute=1&loop=1&controls=0&autoplay=1&playlist=' | append: video_id
      endif
    -%}

    {%- if section.settings.video == blank and section.settings.video_url != blank -%}
      <div class="header__video js-youtube-background-video">
        <iframe
          src="https://www.youtube.com/embed/{{ video_id }}?playsinline=1{{ loop }}"
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      </div>
    {%- else -%}
      {{ section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: "hero__media-custom-video"
      }}
    {%- endif -%}
  </div>

{%- elsif section.settings.image != blank -%}

  <!-- IMAGE -->
  <div class="hero__media">
    <img
      src="{{ section.settings.image | img_url: '2000x' }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="lazy"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
      style="width:100%; height:100%; object-fit:cover;"
    >
  </div>

{%- else -%}

  <!-- FALLBACK -->
  <div class="media__transparent">
    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
  </div>

{%- endif -%}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section-animate>
</div>

{% schema %}
{
  "name": "t:sections.hero-video.name",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "tag": "section",
  "class": "spaced-section--full-width",
  "settings": [
    {
      "type": "text",
      "id": "class",
      "label": "Enter class"
    },
    {
      "type": "header",
      "content": "t:sections.hero-video.settings.header__1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.hero-video.settings.video.label"
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.hero-video.settings.image_height.label",
      "default": 70
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.hero-video.settings.media_position.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.hero-video.settings.media_position.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.hero-video.settings.media_position.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.hero-video.settings.media_position.label",
      "info": "t:sections.hero-video.settings.media_position.info"
    },
    {
      "type": "header",
      "content": "t:sections.hero-video.settings.header__2.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "t:sections.hero-video.settings.video_url.label",
      "info": "t:sections.hero-video.settings.video_url.info"
    },
    {
      "type": "checkbox",
      "id": "autoplay_video",
      "default": true,
      "label": "t:sections.hero-video.settings.autoplay_video.label"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.hero-video.settings.description.label",
      "info": "t:sections.hero-video.settings.description.info"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "t:sections.hero-video.settings.fallback_image.label",
      "info": "t:sections.hero-video.settings.fallback_image.info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "header",
      "content": "t:sections.hero-image.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "content_aligment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.hero-video.settings.content_aligment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.hero-video.settings.content_aligment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.hero-video.settings.content_aligment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.hero-video.settings.content_aligment.label"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 300,
      "max": 800,
      "step": 5,
      "unit": "px",
      "default": 375,
      "label": "t:sections.hero-video.settings.container_width.label"
    },
    {
      "type": "range",
      "id": "vertical_position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50,
      "label": "t:sections.hero-video.settings.vertical_position.label"
    },
    {
      "type": "range",
      "id": "horizontal_position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50,
      "label": "t:sections.hero-video.settings.horizontal_position.label",
      "info": "t:sections.hero-video.settings.horizontal_position.info"
    },
    {
      "type": "checkbox",
      "id": "show_scrim",
      "default": true,
      "label": "t:sections.hero-video.settings.show_scrim.label",
      "info": "t:sections.hero-video.settings.show_scrim.info"
    },
    {
      "type": "range",
      "id": "scrim_lightness",
      "min": 0,
      "max": 255,
      "step": 15,
      "default": 0,
      "label": "t:sections.hero-video.settings.scrim_lightness.label",
      "info": "t:sections.hero-video.settings.scrim_lightness.info"
    },
    {
      "type": "select",
      "id": "video_animation",
      "label": "Video animation",
      "default": "slide-in",
      "options": [
        {
          "value": "none",
          "label": "t:sections.hero-image.settings.image_animation.options__1.label"
        },
        {
          "value": "fade-in",
          "label": "t:sections.hero-image.settings.image_animation.options__2.label"
        },
        {
          "value": "slide-in",
          "label": "t:sections.hero-image.settings.image_animation.options__3.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "default": false,
      "label": "t:sections.hero-image.settings.transparent_header.label",
      "info": "t:sections.hero-image.settings.transparent_header.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing.section_spacing_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.hero-video.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Hero media",
          "label": "t:sections.hero-video.blocks.heading.settings.heading.label"
        },
        {
          "type": "text",
          "id": "subheading",
          "default": "Add optional subheadings",
          "label": "t:sections.hero-video.blocks.heading.settings.subheading.label"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 60,
          "max": 120,
          "step": 1,
          "unit": "%",
          "label": "t:sections.hero-image.blocks.heading.settings.font_size.label",
          "default": 100
        },
        {
          "type": "color",
          "id": "font_color",
          "label": "t:sections.hero-video.blocks.heading.settings.font_color.label",
          "default": "#FFFFFF"
        }
      ]
    },
    {
      "type": "text",
      "name": "Description",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 12,
          "max": 30,
          "step": 1,
          "unit": "px",
          "default": 16,
          "label": "Font size"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Text color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Optional Button",
          "label": "t:sections.hero-image.blocks.buttons.settings.button_label_1.label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "t:sections.hero-image.blocks.buttons.settings.button_link_1.label"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "Optional Button 2",
          "label": "t:sections.hero-image.blocks.buttons.settings.button_label_2.label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "t:sections.hero-image.blocks.buttons.settings.button_link_2.label"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 60,
          "max": 120,
          "step": 1,
          "unit": "%",
          "label": "t:sections.hero-image.blocks.heading.settings.font_size.label",
          "default": 100
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "t:sections.hero-image.blocks.buttons.settings.button_color.label",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "font_button_color",
          "label": "t:sections.hero-image.blocks.buttons.settings.font_button_color.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero-video.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "buttons"
        }
      ]
    }
  ]
}
{% endschema %}
