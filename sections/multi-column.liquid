{{ 'section-steps.css' | asset_url | stylesheet_tag }}

{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
{%- endstyle -%}

<div class="{{section.settings.class}} section-{{ section.id }}-padding">
  <div class="steps-wrapper page-width">

    {% if section.settings.heading != blank %}
      <h2 class="steps-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="steps-grid steps-grid--{{ section.blocks.size }}">
      
      {% for block in section.blocks %}
        <div class="step-item" {{ block.shopify_attributes }}>

            {% if block.settings.image != blank %}
            <div class="step-image">
                <img 
                src="{{ block.settings.image | image_url: width: 600 }}" 
                alt="{{ block.settings.title | escape }}"
                loading="lazy" width="auto" height="auto"
                >
            </div>
            {% endif %}


          {% if block.settings.step_label != blank %}
            <div class="step-label">{{ block.settings.step_label }}</div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="step-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="step-desc">{{ block.settings.description }}</p>
          {% endif %}
           {% if block.settings.image2 != blank %}
                <div class="step-image-2">
                    <img 
                    src="{{ block.settings.image2 | image_url: width: 600 }}" 
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy" width="auto" height="auto"
                    >
                </div>
            {% endif %}
        </div>
      {% endfor %}

    </div>

    {% if section.settings.button_label != blank %}
      <div class="steps-btn">
        <a href="{{ section.settings.button_link }}" class="btn">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Multi Column Section",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
     {
      "type": "text",
      "id": "class",
      "label": "Enter Class"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A simple way to get started"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Find Your Formula"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image",
        },
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label",
          "default": "STEP 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Find the right formula"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add your step description here."
        },
        {
          "type": "image_picker",
          "id": "image2",
          "label": "Select Image 2",
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi Column Section",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}