<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'disclosure.css' | asset_url }}" media="print" onload="this.media='all'">
{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'template-collection.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-product-card.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-collection-skeleton.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  {{ 'component-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
{%- endif -%}

{%- if settings.cart_type == "drawer" and request.page_type != 'cart' -%}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<noscript>{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-search.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-menu-drawer.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-cart-notification.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'disclosure.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  header-drawer {
    justify-self: start;
    margin-left: -0.5rem;
  }

  @media screen and (min-width: 990px) {
    header-drawer {
      display: none;
    }
  }

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: flex;
    flex-wrap: wrap;
  }

  .list-menu__item {
    display: block;
    align-items: center;
    line-height: 1.3;
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: 1.8;
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
</style>

<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
{%- if settings.cart_type == "drawer" and request.page_type != 'cart' -%}
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% liquid
  assign hide_search_icon = false
  if settings.home_search_enabled == true and request.page_type == 'index'
    assign hide_search_icon = true
  endif
  if request.page_type == '404'
    assign hide_search_icon = true
  endif

  assign icon_style = settings.icons_style
  assign cart_icon = settings.cart_icon

  assign highlight_color = section.settings.highlight_color
  assign highlight_links = section.settings.highlight_links | downcase | split: ","

  assign localization_forms = false
  if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
    assign localization_forms = true
  endif
%}

<div class="top-head">
  <div class="page-width">
{% render 'social-icons' %}
</div>
</div>
<sticky-header
  data-background="{{ section.settings.background }}"
  {% if section.settings.enable_sticky %}data-sticky="true"{% endif %}
  {% if section.settings.frosted_glass %}data-frosted="true"{% endif %}
  class="header-wrapper {{ section.settings.font_type }}{% if section.settings.font_style == 'all_caps' %} header-wrapper--uppercase{% endif %}{% if section.settings.frosted_glass %} frosted-header-glass{% endif %}{% if section.settings.enable_sticky == false %} {{ section.settings.background }}{% endif %}" data-page-type="{{ request.page_type }}" data-section-id="{{ section.id }}" data-section-type="header-section" data-header-section>
  <div class="page-width">
    <header class="header header--{{ section.settings.logo_position }}{% if section.settings.main_linklist != blank %} header--has-menu{% endif %}{% if localization_forms %} header--has-localizations{% endif %}" style="--icon-scale: {{ section.settings.icon_size | divided_by: 100.0 }}; --font-section-scale: {{ section.settings.font_size | divided_by: 100.0 }};">
      {%- if section.settings.main_linklist != blank -%}
        <header-drawer data-breakpoint="tablet">
          <details class="menu-drawer-container">
            <summary class="header__icon header__icon--menu header__icon--summary link focus-inset" aria-label="{{ 'sections.header.menu' | t }}">
              <span>
                <i class="icon icon-hamburger {{ icon_style }} fa-bars" style="--fa-secondary-opacity: 1.0"></i>
                <i class="icon icon-close {{ icon_style }} fa-swap-opacity fa-xmark"></i>
              </span>
            </summary>

            <div id="menu-drawer" class="menu-drawer motion-reduce {{ section.settings.background }}" tabindex="-1">
              <div class="menu-drawer__inner-container">
                <div class="menu-drawer__header">
                  {%- if request.page_type == 'index' -%}
                    <h1 class="header__heading">
                  {%- endif -%}
                    <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
                      {%- if section.settings.svg_image != blank -%}
                        <div class="header__heading-logo logo-image" style="max-width: {{ section.settings.logo_width }}px;">
                          {{ section.settings.svg_image }}
                        </div>
                      {%- elsif section.settings.logo != blank -%}
                        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
                        {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
                        {% capture sizes %}(max-width: {{ section.settings.logo_width | times: 2 }}px) 50vw, {{ section.settings.logo_width }}px{% endcapture %}
                        {% capture widths %}{{ section.settings.logo_width | divided_by: 2 }}, {{ section.settings.logo_width | divided_by: 1.5 | round }}, {{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}, {{ section.settings.logo_width | times: 3 }}{% endcapture %}
                        {{ section.settings.logo | image_url: width: 500 | image_tag:
                          class: 'header__heading-logo',
                          widths: widths,
                          height: logo_height,
                          width: section.settings.logo_width,
                          alt: logo_alt,
                          sizes: sizes,
                          preload: true
                        }}
                      {%- else -%}
                        <span class="h2">{{ shop.name }}</span>
                      {%- endif -%}
                    </a>
                  {%- if request.page_type == 'index' -%}
                    </h1>
                  {%- endif -%}
                  <button type="button" class="btn btn--style-2 modal__close-button modal__close-main-button btn-close-modal-text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                    {{ 'accessibility.close' | t }}
                  </button>
                </div>
                <div class="menu-drawer__navigation-container">
                  <nav class="menu-drawer__navigation" style="--active-color: {{ section.settings.active_color.red }}, {{ section.settings.active_color.green }}, {{ section.settings.active_color.blue }};">
                    <ul class="menu-drawer__menu list-menu list-menu--parent" role="list">
                      {%- for link in section.settings.main_linklist.links -%}
                        <li>
                          {%- assign link_title = link.title | downcase | strip -%}
                          {%- assign higlight_title = highlight_links | where: link_title | first -%}

                          {%- if link.links != blank -%}
                            <details>
                              <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}" {% if higlight_title != blank  %} style="color: {{ highlight_color }}"{% endif %}>
                                {{ link.title | escape }}
                                <i class="icon icon-arrow-right icon-close {{ icon_style }} fa-swap-opacity fa-chevron-right"></i>
                              </summary>
                              <div id="link-{{ link.title | escape }}" class="menu-drawer__submenu motion-reduce" tabindex="-1">
                                <div class="menu-drawer__inner-submenu">
                                  <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                    <i class="icon icon-arrow-right icon-close {{ icon_style }} fa-swap-opacity fa-chevron-right"></i>
                                    {{ link.title | escape }}
                                  </button>
                                  <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                    {%- for childlink in link.links -%}
                                      <li>
                                        {% liquid
                                          assign childlink_title = childlink.title | escape
                                          assign childlink_icon = ''
                                          assign child_is_custom = false
                                          assign childlink_array = childlink_title | split: ']'
                                          if childlink_array.size > 1
                                            assign childlink_icon = childlink_array.first | remove: "["
                                            assign childlink_title = childlink_array.last
                                            assign child_has_custom_name = childlink_icon | split: 'icon-'
                                            if child_has_custom_name.size > 1
                                              assign child_is_custom = true
                                              assign icon_child_file_url = childlink_icon | append: '.png' | file_img_url: '100x100'
                                            endif
                                          endif
                                        %}
                                        {%- if childlink.links == blank -%}
                                          <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                            {%- if childlink_icon != '' -%}
                                              {%- if child_is_custom -%}
                                                <span class="header__submenu__icon" style="background-image: url({{ icon_child_file_url }});"></span>
                                              {%- else -%}
                                                <i class="header__submenu__icon {{ icon_style }} fa-{{ childlink_icon }}"></i>
                                              {%- endif -%}
                                            {%- endif -%}
                                            {{ childlink_title }}
                                          </a>
                                        {%- else -%}
                                          <div class="menu-drawer__menu__mobile">
                                            <div class="menu-drawer__menu-item link link--text list-menu__item list-menu__item--title focus-inset">
                                              {%- if childlink_icon != '' -%}
                                                {%- if child_is_custom -%}
                                                  <span class="header__submenu__icon" style="background-image: url({{ icon_child_file_url }});"></span>
                                                {%- else -%}
                                                  <i class="header__submenu__icon {{ icon_style }} fa-{{ childlink_icon }}"></i>
                                                {%- endif -%}
                                              {%- endif -%}
                                              {{ childlink_title }}
                                            </div>
                                            <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                              {%- for grandchildlink in childlink.links -%}
                                                {% liquid
                                                  assign grandchildlink_title = grandchildlink.title | escape
                                                  assign grandchildlink_icon = ''
                                                  assign grandchild_is_custom = false
                                                  assign grandchildlink_array = grandchildlink_title | split: ']'
                                                  if grandchildlink_array.size > 1
                                                    assign grandchildlink_icon = grandchildlink_array.first | remove: "["
                                                    assign grandchildlink_title = grandchildlink_array.last
                                                    assign grandchild_has_custom_name = grandchildlink_icon | split: 'icon-'
                                                    if grandchild_has_custom_name.size > 1
                                                      assign grandchild_is_custom = true
                                                      assign icon_grandchild_file_url = grandchildlink_icon | append: '.png' | file_img_url: '100x100'
                                                    endif
                                                  endif
                                                %}
                                                <li>
                                                  <a href="{{ grandchildlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                    {%- if grandchildlink_icon != '' -%}
                                                      {%- if grandchild_is_custom -%}
                                                        <span class="header__submenu__icon" style="background-image: url({{ icon_grandchild_file_url }});"></span>
                                                      {%- else -%}
                                                        <i class="header__submenu__icon {{ icon_style }} fa-{{ grandchildlink_icon }}"></i>
                                                      {%- endif -%}
                                                    {%- endif -%}
                                                    {{ grandchildlink_title }}
                                                  </a>
                                                </li>
                                              {%- endfor -%}
                                            </ul>
                                          </div>
                                        {%- endif -%}
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </div>
                              </div>
                            </details>
                          {%- else -%}
                            <a href="{{ link.url }}" class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}" {% if higlight_title != blank  %} style="color: {{ highlight_color }}"{% endif %} {% if link.current %} aria-current="page"{% endif %}>
                              {{ link.title | escape }}
                            </a>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}

                      {%- if shop.customer_accounts_enabled -%}
                        <li class="mobile-nav__item border-top">
                          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="menu-drawer__account link focus-inset h5">
                            <div>
                              <i class="icon icon-login {{ icon_style }} fa-user"></i>
                              {%- liquid
                                if customer
                                  echo 'customer.account_fallback' | t
                                else
                                  echo 'customer.log_in' | t
                                endif
                              -%}
                            </div>
                            {%- if customer -%}
                              <span class="menu-drawer__account-email">{{ customer.email }}</span>
                            {%- endif -%}
                          </a>
                        </li>
                      {%- endif -%}

                      {% if section.settings.quick_linklist %}
                        {% for link in section.settings.quick_linklist.links %}
                          <li class="mobile-nav__item{% if shop.customer_accounts_enabled == false and forloop.first %} border-top{% endif %}">
                            {%- if link.links != blank -%}
                              <details>
                                <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}">
                                  {{ link.title | escape }}
                                  <i class="icon icon-arrow-right icon-close {{ icon_style }} fa-swap-opacity fa-chevron-right"></i>
                                </summary>
                                <div id="link-{{ link.title | escape }}" class="menu-drawer__submenu motion-reduce" tabindex="-1">
                                  <div class="menu-drawer__inner-submenu">
                                    <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                                      <i class="icon icon-arrow-right icon-close {{ icon_style }} fa-swap-opacity fa-chevron-right"></i>
                                    </button>
                                    <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                      {%- for childlink in link.links -%}
                                        <li>
                                          {%- if childlink.links == blank -%}
                                            <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                              {{ childlink.title | escape }}
                                            </a>
                                          {%- else -%}
                                            <div>
                                              <div href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                                                {{ childlink.title | escape }}
                                              </div>
                                              <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                                                {%- for grandchildlink in childlink.links -%}
                                                  <li>
                                                    <a href="{{ grandchildlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                                      {{ grandchildlink.title | escape }}
                                                    </a>
                                                  </li>
                                                {%- endfor -%}
                                              </ul>
                                            </div>
                                          {%- endif -%}
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </div>
                                </div>
                              </details>
                            {%- else -%}
                              <a href="{{ link.url }}" class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                                {{ link.title | escape }}
                              </a>
                            {%- endif -%}
                          </li>
                        {% endfor %}
                      {% endif %}
                      <li class="mobile-nav__item">
                        <div class="mobile-localization-wrapper">
                          {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                            <noscript>
                              {%- form 'localization', id: 'HeaderDrawerCountryFormNoScript', class: 'localization-form' -%}
                                <div class="localization-form__select select select--no-background">
                                  <select class="select__select" name="country_code" id="HeaderDrawerCountryLabelNoScript">
                                    {%- for country in localization.available_countries -%}
                                      <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                                        {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                                      </option>
                                    {%- endfor -%}
                                  </select>
                                  <span class="select-highlight"></span>
                                  <label class="facet-filters__label form__label select-label" for="HeaderDrawerCountryLabelNoScript">
                                    {{ 'localization.country_label' | t }}
                                  </label>
                                  {% render 'icon-chevron-down' %}
                                </div>
                                <button class="btn btn--secondary btn--small">{{ 'localization.update' | t }}</button>
                              {%- endform -%}
                            </noscript>
                            <localization-form class="no-js-hidden">
                              {%- form 'localization', id: 'HeaderDrawerCountryForm', class: 'localization-form' -%}
                                <div class="no-js-hidden">
                                  <div class="disclosure">
                                    <span class="visually-hidden" id="HeaderDrawerCountryLabel">{{ 'localization.country_label' | t }}</span>
                                    <button type="button" class="disclosure__button localization-form__select localization-selector link link--text caption-large" aria-expanded="false" aria-controls="HeaderDrawerCountryList" aria-describedby="HeaderDrawerCountryLabel">
                                      {% render 'icon-currency', currency_iso: localization.country.iso_code %}
                                      <span class="localization-form__iso-code">{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
                                      <i class="icon {{ icon_style }} fa-chevron-down" style="--fa-secondary-opacity: 1;"></i>
                                    </button>
                                    <div id="HeaderDrawerCountryList" class="localization-list disclosure__list background-modal" hidden>
                                      <div class="localization-list__inner">
                                        <div class="localization-list__header">
                                          <h2>{{ 'sections.footer.delivery_destination' | t }}</h2>
                                          <p>
                                            {% assign country_count = 1 %}
                                            {% if localization.country.name == "United States"
                                              or localization.country.name == "United Kingdom"
                                              or localization.country.name == "Dominican Republic"
                                              or localization.country.name == "Maldives"
                                              or localization.country.name == "Maldives"
                                              or localization.country.name == "Marshall Islands"
                                              or localization.country.name == "Philippines"
                                              or localization.country.name == "Solomon Islands"
                                              or localization.country.name == "United Arab Emirates" %}
                                              {% assign country_count = 2 %}
                                            {% endif %}
                                            {{ 'sections.footer.delivery_destination_content' | t: country_name: localization.country.name, count: country_count }} {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}.
                                          </p>
                                          <div class="localization-list__search">
                                            <input
                                              id="localization-search-input"
                                              autocomplete="off"
                                              class="dd-searchbox"
                                              type="text"
                                              value=""
                                              placeholder="Search for a destination"
                                            >
                                            <span class="field__button button--icon" aria-label="Search for a destination">
                                              <i class="icon icon-search {{ icon_style }} fa-magnifying-glass"></i>
                                            </span>
                                          </div>
                                          <div class="localization__item--active">
                                            {% render 'icon-currency', currency_iso: localization.country.iso_code %}
                                            <div class="localization-form__country-name">{{ localization.country.name }} <span>({{ 'sections.footer.selected' | t }})</span></div>
                                            <span class="localization-form__currency">{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
                                          </div>
                                          <button type="button" class="btn btn--style-2 modal__close-button btn-close-modal-text localization-selector focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                                            {{ 'accessibility.close' | t }}
                                          </button>
                                        </div>
                                        <div class="localization-list__content">
                                          <ul role="list" class="list-unstyled">
                                            {%- for country in localization.available_countries -%}
                                              <li class="disclosure__item{% if country.iso_code == localization.country.iso_code %} hide{% endif %}" tabindex="-1">
                                                <a class="link link--text disclosure__link caption-large focus-inset" href="#"{% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %} data-value="{{ country.iso_code }}">
                                                  {% render 'icon-currency', currency_iso: country.iso_code %}
                                                  <div class="localization-form__country-name">{{ country.name }}</div> <span class="localization-form__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                                                </a>
                                              </li>
                                            {%- endfor -%}
                                            <li class="disclosure__no-results hide">
                                              <p>{{ 'sections.footer.no_results' | t }}</p>
                                            </li>
                                          </ul>
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                  <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
                                </div>
                              {%- endform -%}
                            </localization-form>
                          {%- endif -%}

                          {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                            <noscript>
                              {%- form 'localization', id: 'HeaderDrawerLanguageFormNoScript', class: 'localization-form' -%}
                                <div class="localization-form__select select select--no-background">
                                  <select class="select__select" name="locale_code" id="HeaderDrawerLanguageLabelNoScript">
                                    {%- for language in localization.available_languages -%}
                                      <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {%- if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                                        {{ language.endonym_name | capitalize }}
                                      </option>
                                    {%- endfor -%}
                                  </select>
                                  <span class="select-highlight"></span>
                                  <label class="facet-filters__label form__label select-label" for="HeaderDrawerLanguageLabelNoScript">
                                    {{ 'localization.language_label' | t }}
                                  </label>
                                  {% render 'icon-chevron-down' %}
                                </div>
                                <button class="btn btn--secondary btn--small">{{ 'localization.update' | t }}</button>
                              {%- endform -%}
                            </noscript>
                            <localization-form class="no-js-hidden">
                              {%- form 'localization', id: 'HeaderDrawerLanguageForm', class: 'localization-form' -%}
                                <div class="no-js-hidden">
                                  <div class="disclosure">
                                    <span class="visually-hidden" id="HeaderDrawerLanguageLabel">{{ 'localization.language_label' | t }}</span>
                                    <button type="button" class="disclosure__button localization-form__select localization-selector link link--text caption-large" aria-expanded="false" aria-controls="HeaderDrawerLanguageList" aria-describedby="HeaderDrawerLanguageLabel">
                                      {{ localization.language.endonym_name | capitalize }}
                                      <i class="icon {{ icon_style }} fa-chevron-down" style="--fa-secondary-opacity: 1;"></i>
                                    </button>
                                    <div id="HeaderDrawerLanguageList" class="localization-list disclosure__list background-modal" hidden>
                                      <div class="localization-list__inner">
                                        <div class="localization-list__header">
                                          <h2>{{ 'sections.footer.change_language' | t }}</h2>
                                          <button type="button" class="btn btn--style-2 modal__close-button localization-selector btn-close-modal-text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                                            {{ 'accessibility.close' | t }}
                                          </button>
                                        </div>
                                        <div class="localization-list__content">
                                          <ul role="list" class="list-unstyled">
                                            {%- for language in localization.available_languages -%}
                                              <li class="disclosure__item{% if language.iso_code == localization.language.iso_code %} disclosure__item--active{% endif %}" tabindex="-1">
                                                <a class="link link--text disclosure__link caption-large focus-inset" href="#" hreflang="{{ language.iso_code }}" lang="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} aria-current="true"{% endif %} data-value="{{ language.iso_code }}">
                                                  {% if language.iso_code == localization.language.iso_code %}
                                                    <i class="icon {{ icon_style }} fa-check"></i>
                                                  {% endif %}
                                                  {{ language.endonym_name | capitalize }}
                                                </a>
                                              </li>
                                            {%- endfor -%}
                                          </ul>
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                  <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
                                </div>
                              {%- endform -%}
                            </localization-form>
                          {%- endif -%}
                        </div>
                      </li>
                    </ul>
                  </nav>
                </div>
              </div>
            </div>
          </details>
        </header-drawer>
      {%- endif -%}

      {%- if section.settings.logo_position == 'top-center' or section.settings.main_linklist == blank -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset{% if section.settings.main_linklist != blank %} small--hide{% endif %}">
            <i class="icon {{ icon_style }} fa-user"></i>
            <span class="visually-hidden">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo 'customer.log_in' | t
                endif
              -%}
            </span>
          </a>
        {%- endif -%}
      {%- endif -%}

      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
            {%- if section.settings.svg_image != blank -%}
              <div class="header__heading-logo logo-image" style="max-width: {{ section.settings.logo_width }}px;">
                {{ section.settings.svg_image }}
              </div>
            {%- elsif section.settings.logo != blank -%}
              {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
              {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
              {% capture sizes %}(max-width: {{ section.settings.logo_width | times: 2 }}px) 50vw, {{ section.settings.logo_width }}px{% endcapture %}
              {% capture widths %}{{ section.settings.logo_width | divided_by: 2 }}, {{ section.settings.logo_width | divided_by: 1.5 | round }}, {{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}, {{ section.settings.logo_width | times: 3 }}{% endcapture %}
              {{ section.settings.logo | image_url: width: 500 | image_tag:
                class: 'header__heading-logo',
                widths: widths,
                height: logo_height,
                width: section.settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
              }}
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.logo_position == 'top-center' or section.settings.logo_position == 'top-left' -%}
        <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header__localization{% endif %}">
          <div class="desktop-localization-wrapper">
            {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
              <noscript>
                {%- form 'localization', id: 'HeaderLanguageFormNoScript', class: 'localization-form' -%}
                  <div class="localization-form__select select select--no-background">
                    <select class="select__select" name="locale_code" id="HeaderLanguageLabelNoScript">
                      {%- for language in localization.available_languages -%}
                        <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {%- if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                          {{ language.endonym_name | capitalize }}
                        </option>
                      {%- endfor -%}
                    </select>
                    <span class="select-highlight"></span>
                    <label class="facet-filters__label form__label select-label" for="HeaderLanguageLabelNoScript">
                      {{ 'localization.language_label' | t }}
                    </label>
                    {% render 'icon-chevron-down' %}
                  </div>
                  <button class="btn btn--secondary btn--small">{{ 'localization.update' | t }}</button>
                {%- endform -%}
              </noscript>
              <localization-form class="no-js-hidden">
                {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
                  <div class="no-js-hidden">
                    <div class="disclosure">
                      <span class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</span>
                      <button type="button" class="disclosure__button localization-form__select localization-selector link link--text caption-large" aria-expanded="false" aria-controls="HeaderLanguageList" aria-describedby="HeaderLanguageLabel">
                        {{ localization.language.endonym_name | capitalize }}
                      </button>
                      <div id="HeaderLanguageList" class="localization-list disclosure__list background-modal" hidden>
                        <div class="localization-arrow" aria-hidden="true"></div>
                        <div class="localization-list__inner">
                          <div class="localization-list__header">
                            <h2>{{ 'sections.footer.change_language' | t }}</h2>
                            <button type="button" class="btn btn--style-2 modal__close-button btn-close-modal-text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                              {{ 'accessibility.close' | t }}
                            </button>
                          </div>
                          <div class="localization-list__content">
                            <ul role="list" class="list-unstyled">
                              {%- for language in localization.available_languages -%}
                                <li class="disclosure__item{% if language.iso_code == localization.language.iso_code %} disclosure__item--active{% endif %}" tabindex="-1">
                                  <a class="link link--text disclosure__link caption-large focus-inset" href="#" hreflang="{{ language.iso_code }}" lang="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} aria-current="true"{% endif %} data-value="{{ language.iso_code }}">
                                    {% if language.iso_code == localization.language.iso_code %}
                                      <i class="icon {{ icon_style }} fa-check"></i>
                                    {% endif %}
                                    {{ language.endonym_name | capitalize }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          </div>
                        </div>
                      </div>
                    </div>
                    <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
            {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
              <noscript>
                {%- form 'localization', id: 'HeaderCountryFormNoScript', class: 'localization-form' -%}
                  <div class="localization-form__select select select--no-background">
                    <select class="select__select" name="country_code" id="HeaderCountryLabelNoScript">
                      {%- for country in localization.available_countries -%}
                        <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                          {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                        </option>
                      {%- endfor -%}
                    </select>
                    <span class="select-highlight"></span>
                    <label class="facet-filters__label form__label select-label" for="HeaderCountryLabelNoScript">
                      {{ 'localization.country_label' | t }}
                    </label>
                    {% render 'icon-chevron-down' %}
                  </div>
                  <button class="btn btn--secondary btn--small">{{ 'localization.update' | t }}</button>
                {%- endform -%}
              </noscript>
              <localization-form class="no-js-hidden">
                {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
                  <div class="no-js-hidden">
                    <div class="disclosure">
                      <span class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</span>
                      <button type="button" class="disclosure__button localization-form__select localization-selector link link--text caption-large" aria-expanded="false" aria-controls="HeaderCountryList" aria-describedby="HeaderCountryLabel">
                        {% render 'icon-currency', currency_iso: localization.country.iso_code %}
                      </button>
                      <div id="HeaderCountryList" class="localization-list disclosure__list background-modal" hidden>
                        <div class="localization-arrow" aria-hidden="true"></div>
                        <div class="localization-list__inner">
                          <div class="localization-list__header">
                            <h2>{{ 'sections.footer.delivery_destination' | t }}</h2>
                            <p>
                              {% assign country_count = 1 %}
                              {% if localization.country.name == "United States"
                                or localization.country.name == "United Kingdom"
                                or localization.country.name == "Dominican Republic"
                                or localization.country.name == "Maldives"
                                or localization.country.name == "Maldives"
                                or localization.country.name == "Marshall Islands"
                                or localization.country.name == "Philippines"
                                or localization.country.name == "Solomon Islands"
                                or localization.country.name == "United Arab Emirates" %}
                                {% assign country_count = 2 %}
                              {% endif %}
                              {{ 'sections.footer.delivery_destination_content' | t: country_name: localization.country.name, count: country_count }} {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}.
                            </p>
                            <div class="localization-list__search">
                              <input
                                id="localization-search-input"
                                autocomplete="off"
                                class="dd-searchbox"
                                type="text"
                                value=""
                                placeholder="Search for a destination"
                              >
                              <span class="field__button button--icon" aria-label="Search for a destination">
                                <i class="icon icon-search {{ icon_style }} fa-magnifying-glass"></i>
                              </span>
                            </div>
                            <div class="localization__item--active">
                              {% render 'icon-currency', currency_iso: localization.country.iso_code %}
                              <div class="localization-form__country-name">{{ localization.country.name }} <span>({{ 'sections.footer.selected' | t }})</span></div>
                              <span class="localization-form__currency">{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
                            </div>
                            <button type="button" class="btn btn--style-2 modal__close-button btn-close-modal-text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                              {{ 'accessibility.close' | t }}
                            </button>
                          </div>
                          <div class="localization-list__content">
                            <ul role="list" class="list-unstyled">
                              {%- for country in localization.available_countries -%}
                                <li class="disclosure__item{% if country.iso_code == localization.country.iso_code %} hide{% endif %}" tabindex="-1">
                                  <a class="link link--text disclosure__link caption-large focus-inset" href="#"{% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %} data-value="{{ country.iso_code }}">
                                    {% render 'icon-currency', currency_iso: country.iso_code %}
                                    <div class="localization-form__country-name">{{ country.name }}</div> <span class="localization-form__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                                  </a>
                                </li>
                              {%- endfor -%}
                              <li class="disclosure__no-results hide">
                                <p>{{ 'sections.footer.no_results' | t }}</p>
                              </li>
                            </ul>
                          </div>
                        </div>
                      </div>
                    </div>
                    <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
          </div>
          <details-modal class="header__search{% unless settings.predictive_search_enabled %} search-modal--predictive-disabled{% endunless %}{% if request.page_type == 'search' or hide_search_icon %} hidden{% endif %}">
            <details>
              <summary class="header__icon header__icon--search header__icon--summary link focus-inset modal__toggle" aria-haspopup="dialog" aria-label="{{ 'general.search.search' | t }}">
                <div>
                  <span class="header__icon--search__icon">
                    <i class="icon {{ icon_style }} fa-magnifying-glass"></i>
                  </span>
                  <span class="header__icon--search__text">{{ 'general.search.search' | t }}</span>
                </div>
              </summary>
              <div class="search-modal modal__content main-background" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
                <div class="modal-overlay"></div>
                <div class="search-modal__content page-width">
                  {%- if settings.predictive_search_enabled -%}
                    <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
                  {%- endif -%}
                    <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
                      <div class="search-form__input-wrapper">
                        <input class="search__input field__input"
                          id="Search-In-Modal"
                          type="search"
                          name="q"
                          value=""
                          placeholder="{{ 'general.search.search' | t }}"
                          {%- if settings.predictive_search_enabled -%}
                            role="combobox"
                            aria-expanded="false"
                            aria-owns="predictive-search-results-list"
                            aria-controls="predictive-search-results-list"
                            aria-haspopup="listbox"
                            aria-autocomplete="list"
                            autocorrect="off"
                            autocomplete="off"
                            autocapitalize="off"
                            spellcheck="false"
                          {%- endif -%}
                        >
                        <input type="hidden" name="options[prefix]" value="last">
                        <button type="button" class="modal__close-button link link--text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                          {{ 'templates.search.close' | t }}
                        </button>
                        <button class="search__button field__button button--icon" aria-label="{{ 'general.search.search' | t }}">
                          <i class="icon icon-search {{ icon_style }} fa-magnifying-glass"></i>
                        </button>
                      </div>

                      {%- if settings.predictive_search_enabled -%}
                        <div class="predictive-search predictive-search--header" data-predictive-search>
                          <div class="predictive-search__loading-state">
                            <span class="predictive-search__loading-state">
                              <div class="spinner">
                                <div class="bounce1"></div>
                                <div class="bounce2"></div>
                                <div class="bounce3"></div>
                              </div>
                              <span class="spinner-text">{{ 'templates.search.searching' | t }}</span>
                            </span>
                          </div>
                        </div>

                        <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                      {%- endif -%}
                    </form>
                  {%- if settings.predictive_search_enabled -%}
                    </predictive-search>
                  {%- endif -%}
                </div>
              </div>
            </details>
          </details-modal>

          {%- if shop.customer_accounts_enabled -%}
            <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset{% if section.settings.main_linklist != blank %} small--hide{% endif %}">
              <i class="icon {{ icon_style }} fa-user"></i>
              <span class="visually-hidden">
                {%- liquid
                  if customer
                    echo 'customer.account_fallback' | t
                  else
                    echo 'customer.log_in' | t
                  endif
                -%}
              </span>
            </a>
          {%- endif -%}

          {% unless request.page_type == 'cart' %}
            <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
              <i class="icon {{ icon_style }} fa-{{ cart_icon }}"></i>
              <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
              {%- if cart != empty -%}
                <div class="cart-count-bubble">
                  {%- if cart.item_count < 1000 -%}
                    <span aria-hidden="true">{{ cart.item_count }}</span>
                  {%- endif -%}
                  <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
                </div>
              {%- endif -%}
            </a>
          {% endunless %}
        </div>
      {%- endif -%}

      {%- if section.settings.main_linklist != blank -%}
        <nav class="header__inline-menu">
          <ul class="list-menu list-menu--inline" role="list">
            {%- for link in section.settings.main_linklist.links -%}
              <li class="list-menu__item-list">
                {%- assign link_title = link.title | downcase | strip -%}
                {%- assign higlight_title = highlight_links | where: link_title | first -%}

                {%- if link.links != blank -%}
                  <details-disclosure>
                    <details class="details--list-menu">
                      <summary class="header__menu-item list-menu__item link focus-inset{%- if link.child_active and request.page_type != 'product' %} header__active-menu-item{% endif %}" {% if higlight_title != blank  %} style="color: {{ highlight_color }}"{% endif %}>
                        <span {% if higlight_title != blank  %} style="color: {{ highlight_color }}"{% endif %}>
                          <a class="no-js-hidden" href="{{ link.url }}" {% if higlight_title != blank  %} style="color: {{ highlight_color }}"{% endif %}>
                            {{ link.title | escape }}
                            <i class="icon-arrow {{ icon_style }} fa-swap-opacity fa-chevron-down"></i>
                          </a>
                          <noscript>{{ link.title | escape }} <i class="icon icon-arrow-right icon-close {{ icon_style }} fa-swap-opacity fa-chevron-right"></i></noscript>
                        </span>
                      </summary>
                      <div class="header__submenu list-menu--disclosure motion-reduce {{ section.settings.custom_background }}">
                        <div class="site-header__categories__menu page-width">
                          <ul class="list-menu site-header__categories__list-content" role="list" tabindex="-1" {% if link.links.size < 6 %}style="--columns-number: {{ link.links.size }}"{% endif %}>
                            {%- for childlink in link.links -%}
                              <li {% if childlink.links.size > 0 %}class="list-menu__has-children"{% endif %}>
                                {% liquid
                                  assign childlink_title = childlink.title | escape
                                  assign childlink_icon = ''
                                  assign child_is_custom = false
                                  assign childlink_array = childlink_title | split: ']'
                                  if childlink_array.size > 1
                                    assign childlink_icon = childlink_array.first | remove: "["
                                    assign childlink_title = childlink_array.last
                                    assign child_has_custom_name = childlink_icon | split: 'icon-'
                                    if child_has_custom_name.size > 1
                                      assign child_is_custom = true
                                      assign icon_child_file_url = childlink_icon | append: '.png' | file_img_url: '100x100'
                                    endif
                                  endif
                                %}
                                {%- if childlink.links == blank -%}
                                  <a href="{{ childlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset{% if childlink.current %} list-menu__item--active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                                    {%- if childlink_icon != '' -%}
                                      {%- if child_is_custom -%}
                                        <span class="header__submenu__icon" style="background-image: url({{ icon_child_file_url }});"></span>
                                      {%- else -%}
                                        <i class="header__submenu__icon {{ icon_style }} fa-{{ childlink_icon }}"></i>
                                      {%- endif -%}
                                    {%- endif -%}
                                    {{ childlink_title }}
                                  </a>
                                {%- else -%}
                                  <div class="header__submenu__categories">
                                    <div class="header__menu-item link--text list-menu__item focus-inset">
                                      {%- if childlink_icon != '' -%}
                                        {%- if child_is_custom -%}
                                          <span class="header__submenu__icon" style="background-image: url({{ icon_child_file_url }});"></span>
                                        {%- else -%}
                                          <i class="header__submenu__icon {{ icon_style }} fa-{{ childlink_icon }}"></i>
                                        {%- endif -%}
                                      {%- endif -%}
                                      {{ childlink_title }}
                                    </div>
                                    <ul class="header__submenu list-menu">
                                      {%- for grandchildlink in childlink.links -%}
                                        {% liquid
                                          assign grandchildlink_title = grandchildlink.title | escape
                                          assign grandchildlink_icon = ''
                                          assign grandchild_is_custom = false
                                          assign grandchildlink_array = grandchildlink_title | split: ']'
                                          if grandchildlink_array.size > 1
                                            assign grandchildlink_icon = grandchildlink_array.first | remove: "["
                                            assign grandchildlink_title = grandchildlink_array.last
                                            assign grandchild_has_custom_name = grandchildlink_icon | split: 'icon-'
                                            if grandchild_has_custom_name.size > 1
                                              assign grandchild_is_custom = true
                                              assign icon_grandchild_file_url = grandchildlink_icon | append: '.png' | file_img_url: '100x100'
                                            endif
                                          endif
                                        %}
                                        <li>
                                          <a href="{{ grandchildlink.url }}" class="header__menu-item list-menu__item link link--text focus-inset{% if grandchildlink.current %} list-menu__item--active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                            {%- if grandchildlink_icon != '' -%}
                                              {%- if grandchild_is_custom -%}
                                                <span class="header__submenu__icon" style="background-image: url({{ icon_grandchild_file_url }});"></span>
                                              {%- else -%}
                                                <i class="header__submenu__icon {{ icon_style }} fa-{{ grandchildlink_icon }}"></i>
                                              {%- endif -%}
                                            {%- endif -%}
                                            {{ grandchildlink_title }}
                                          </a>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </div>
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                          {% if section.blocks.size > 0 %}
                            <div class="header__submenu__col">
                              {% assign promo_block = section.blocks | map: 'settings' | where: "menu_item", link.title | first %}
                              {% if promo_block %}
                                {% for i in (1..2) %}
                                  {% capture image %}image_{{i}}{% endcapture %}
                                  {% capture title %}title_{{i}}{% endcapture %}
                                  {% capture subtitle %}subtitle_{{i}}{% endcapture %}
                                  {% capture promo_link %}link_{{i}}{% endcapture %}
                                  {% capture text_color %}text_color_{{i}}{% endcapture %}
                                  {% capture show_scrim %}show_scrim_{{i}}{% endcapture %}
                                  {% capture scrim_lightness_background %}scrim_lightness_background_{{i}}{% endcapture %}
                                  {% if promo_block[image] != blank or promo_block[title] != blank or promo_block[subtitle] != blank %}
                                    <div class="header__submenu__col_img{% if promo_block[show_scrim] %} header__submenu__col_img--scrim{% endif %}" style="--promo-size: {{ promo_block.image_size }}px; --scrim-lightness: {{ promo_block[scrim_lightness_background] }}, {{ promo_block[scrim_lightness_background] }}, {{ promo_block[scrim_lightness_background] }}; --font-section-scale: {{ promo_block.font_size | divided_by: 100.0 }};">
                                      {% if promo_block[promo_link] != blank %}
                                        <a href="{{ promo_block[promo_link] }}">
                                      {% endif %}
                                        {% if promo_block[image] != blank %}
                                          {% capture sizes %}(max-width: {{ promo_block.image_size | times: 2 }}px) 50vw, {{ promo_block.image_size  }}px{% endcapture %}
                                          <div class="media media--square">
                                            {% assign promo_block_image = promo_block[image] %}
                                            {{ promo_block_image | image_url: width: 520 | image_tag:
                                              loading: 'lazy',
                                              widths: '300, 400, 520',
                                              alt: promo_block_image.alt | default: 'Promotion',
                                              width: promo_block_image.width,
                                              height: promo_block_image.height,
                                              sizes: sizes
                                            }}
                                          </div>
                                        {% endif %}
                                        <h3 style="color: {{ promo_block[text_color] }};">{{ promo_block[title] }} <i>{{ promo_block[subtitle] }}</i></h3>
                                      {% if promo_block[promo_link] != blank %}
                                        </a>
                                      {% endif %}
                                    </div>
                                  {% endif %}
                                {% endfor %}
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    </details>
                  </details-disclosure>
                {%- else -%}
