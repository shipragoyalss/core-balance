<script src="{{ 'product-information.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign icon_style = settings.icons_style
  assign uppercase_product_title = settings.uppercase_product_title
  assign border_gallery = settings.product_gallery_border
  assign border_color = settings.product_gallery_border_color
  assign enable_image_zoom = section.settings.enable_image_zoom
  assign product_image_zoom_size = '2000'
  assign product_image_scale = '0'

  assign height = 1070

  if product.type == 'Gift Card'
    assign enable_image_zoom = false
  endif

  assign media_ratio = settings.image_ratio
  assign product_swatches = settings.product_swatches | downcase | split: ','

  for option in product.options_with_values
    assign option_name =  option.name | downcase | strip
    assign option_swatch = product_swatches | where: option_name
  endfor

  if product.media.size < 1
    assign hide_gallery = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0px;
    padding-bottom: 0px;
  }

  @media screen and (min-width: 1000px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<product-information
  id="MainProduct-{{ section.id }}"
  class="product-template__container section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-social-sharing.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
  {{ 'section-size-chart.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    {{ 'component-product-modal.css' | asset_url | stylesheet_tag }}
    <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
    <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endif -%}

  {% if section.settings.show_breadcrumbs %}
    <div class="page-width{% unless collection.url %} breadcrumbs-mobile--hide{% endunless %}">
      <nav class="breadcrumbs" role="navigation" aria-label="breadcrumbs">
        <ol class="breadcrumbs__list background-modal">
          <li class="breadcrumbs__item">
            <a class="breadcrumbs__link" href="{{ routes.root_url }}">
              <i class="icon icon-home {{ icon_style }} fa-house"></i>
              <span class="visually-hidden">Home</span>
            </a>
          </li>
          {%- if collection.url -%}
            <li class="breadcrumbs__item breadcrumbs__item--collection">
              <a href="{{ collection.url }}"><span>{{ 'products.product.see_breadcrumb' | t }}</span> {{ collection.title }}</a>
            </li>
          {%- endif -%}
          <li class="breadcrumbs__item">
            <a class="breadcrumbs__link" href="{{ product.url }}" aria-current="page">{{ product.title }}</a>
          </li>
        </ol>
      </nav>
    </div>
  {% endif %}

  <div class="product-page__content product-single__page-wrap page-width page-width--product clearfix{% unless section.settings.show_breadcrumbs %} product-page__content--padding{% endunless %}">
    {% unless hide_gallery %}
      <media-gallery class="grid__item product__media-wrapper" style="--border-gallery-color: {{ border_color }};" id="MediaGallery-{{ section.id }}" data-section="{{ section.id }}" data-enable-all-images="{{ section.settings.enable_all_images }}" data-product-swatches="{{ settings.product_swatches | downcase }}">
        {%- if product.media.size > 0 -%}
          {%- liquid
            assign featured_media_aspect_ratio = product.media[0].aspect_ratio

            if product.featured_media.aspect_ratio == nil
              assign featured_media_aspect_ratio = 1
            endif
          -%}
          <slider-component class="product-single__media-group no-js-hidden{% if section.settings.media_size == 'full' %} product-single__media-group--full{% endif %}" data-product-single-media-group>
            <a class="skip-to-content-link btn visually-hidden quick-add-hidden" href="#ProductInfo-{{ section.id }}">
              {{ "accessibility.skip_to_product_info" | t }}
            </a>
            <div class="product-single__media-group__wrap">
              {% assign height_gallery = '100' %}
              {% case media_ratio %}
                {%- when 'portrait' -%}
                  {% assign height_gallery = '125' %}
                {%- when 'adapt' -%}
                  {% assign height_gallery =  1 | divided_by: featured_media_aspect_ratio | times: 100 %}
              {%- endcase -%}
              <div class="product-single__wrapper" style="--padding: {{ height_gallery | append: '%' }};">
                <ul class="product-single__gallery product-single__gallery-{{ section.id }}{% if border_gallery %} product__gallery--border{% endif %}">
                  {% assign productMedias = product.media %}
                  {% assign current_alt = '' %}
                  {%- for media in productMedias -%}
                    <li class="product-single__gallery-item" data-alt="{{ media.alt }}" data-media-id="{{ section.id }}-{{ media.id }}">
                      {%- liquid
                        assign lazy_load = true
                        assign gallery_media_alt = media.alt | escape | escape | camelcase
                        if gallery_media_alt != blank and current_alt != gallery_media_alt
                          assign current_alt = gallery_media_alt
                          assign lazy_load = false
                        endif
                        render 'media', media: media, height: height, enable_image_zoom: enable_image_zoom, image_zoom_size: product_image_zoom_size, image_scale: product_image_scale, lazy_load: lazy_load
                      -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
              {% if product.media.size > 1 and product.type != 'Gift Card' %}
                <div class="thumbnails-wrapper background-modal">
                  {% liquid
                    capture color_selected
                      if option_swatch.size > 0
                        for value in product_option.values
                          if product_option.selected_value == value
                            echo value | strip | camelize
                          endif
                        endfor
                      endif
                    endcapture
                  %}
                  <ul class="product-single__thumbnails product-single__thumbnails-{{ section.id }}">
                    {% for media in product.media %}
                      {% assign media_alt = media.alt %}
                      <li class="product-single__thumbnails-item js{% if color_selected != blank and media_alt != color_selected %} product-single__thumbnails--hide{% endif %}">
                        <div class="product-single__thumbnail-wrap text-link product-single__thumbnail product-single__thumbnail--{{ section.id }}{% if border_gallery %} product__gallery--border{% endif %}"
                          data-thumbnail-id="{{ section.id }}-{{ media.id }}">
                          <div class="media media--{{ media_ratio }}"
                            {% if media_ratio == 'adapt' %} style="padding-bottom: {{ 1 | divided_by: featured_media_aspect_ratio | times: 100 }}%;"{% endif %}
                          >
                            {%- capture thumbnailAlt -%}
                              {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                                {{ 'products.product.video_thumbnail_alt' | t: imageAlt: media_alt }}
                              {%- elsif media.media_type == 'model' -%}
                                {{ 'products.product.model_thumbnail_alt' | t: imageAlt: media_alt }}
                              {%- else -%}
                                {{ 'products.product.gallery_thumbnail_alt' | t: imageAlt: media_alt }}
                              {%- endif -%}
                            {%- endcapture -%}

                            <img class="product-single__thumbnail-image lazyload"
                              srcset="{% if media.preview_image.width >= 66 %}{{ media.preview_image | image_url: width: 66 }} 66w,{% endif %}
                                      {% if media.preview_image.width >= 110 %}{{ media.preview_image | image_url: width: 110 }} 110w,{% endif %}
                                      {% if media.preview_image.width >= 84 %}{{ media.preview_image | image_url: width: 84 }} 84w,{% endif %}
                                      {% if media.preview_image.width >= 168 %}{{ media.preview_image | image_url: width: 168 }} 168w,{% endif %}
                                      {% if media.preview_image.width >= 132 %}{{ media.preview_image | image_url: width: 132 }} 132w,{% endif %}"
                              src="{{ media | image_url: width: 118 }}"
                              sizes="(min-width: 1000px) 110px, (min-width: 750px) 118px, 168px"
                              alt="{{ thumbnailAlt }}"
                              data-alt="{{ media_alt }}"
                              width="110"
                              height="{{ 110 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                              loading="lazy"
                            >
                            {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                              <div class="product-single__thumbnail-badge media__badge">
                                <i class="icon icon-play {{ icon_style }} fa-circle-play"></i>
                              </div>
                            {%- endif -%}
                            {%- if media.media_type == 'model' -%}
                              <div class="product-single__thumbnail-badge media__badge">
                                {% render 'icon-3d-badge-full-color' %}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            </div>
          </slider-component>
          <noscript class="product-single__media__noscript-wrapper-{{ section.id }}">
            <div class="product-single__media-group {% if section.settings.media_size == 'full' %} product-single__media-group--full{% endif %}">
              <div class="product-single__media-group__wrap">
                {% assign height_gallery = '100' %}
                {% case media_ratio %}
                  {%- when 'portrait' -%}
                    {% assign height_gallery = '125' %}
                  {%- when 'adapt' -%}
                    {% assign height_gallery =  1 | divided_by: featured_media_aspect_ratio | times: 100 %}
                {%- endcase -%}
                <div class="product-single__wrapper" style="--padding: {{ height_gallery | append: '%' }};">
                  <ul class="product-single__gallery product-single__gallery-{{ section.id }}">
                    <li class="product-single__gallery-item" data-alt="{{ product.media.first | escape | camelcase }}">
                      <a name="picture{{ forloop.index }}"></a>
                      {% render 'media', media: product.media.first, height: height %}
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </noscript>
        {%- else -%}
          <div class="product__media-empty">
            <h4>{{ 'general.image_coming' | t }}</h4>
          </div>
        {%- endif -%}
      </media-gallery>
    {% endunless %}
    <div class="product__info-wrapper grid__item{% unless section.settings.show_breadcrumbs %} product__info-wrapper--no-padding{% endunless %}{% if hide_gallery %} product__info-wrapper--static{% endif %}">
      {% unless hide_gallery %}
        <div id="product__buy-tools-trigger"></div>
      {% endunless %}
      <div id="ProductInfo-{{ section.id }}" class="product__info-container product__info-container--sticky">
        <div class="product-single__meta load-skeleton{% if product.type == 'Gift Card' %} product-single__meta--gift-card{% endif %}">
          <div class="product__meta-grid">
            {%- assign product_form_id = 'product-form-' | append: section.id -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'selling_features' -%}
                {% liquid
                  assign product_tagged = false
                  assign theme_tags = settings.product_tags | downcase | split: ','
                  assign product_tags = product.tags | join: ', ' | downcase | split: ','
                  for tag in theme_tags
                    assign handled_tag = tag | downcase | strip
                    assign tagged = product_tags | where: handled_tag | first
                    if tagged
                      assign product_tagged = true
                      break
                    endif
                  endfor
                %}
                {% capture hide_class %}
                  {% if product_tagged == false and block.settings.show_rating == false %}
                    hidden
                  {% elsif product_tagged == false and product.metafields.reviews.rating.value == blank %}
                    hidden
                  {% endif %}
                {% endcapture %}
                <div class="product-promo-content {{ hide_class }}">
                  {% render 'product-tags', product: product %}
                  {% if block.settings.show_rating %}
                    {% liquid
                      assign rating = product.metafields.reviews.rating.value
                      assign value_rating = product.metafields.reviews.rating.value.rating
                      assign scale_max = product.metafields.reviews.rating.value.scale_max
                      assign rating_count = product.metafields.reviews.rating_count
                    %}

                    {%- if rating != blank -%}
                      {% liquid
                        assign rating_decimal = 0
                        assign decimal = value_rating | modulo: 1
                        if decimal >= 0.3 and decimal <= 0.7
                          assign rating_decimal = 0.5
                        elsif decimal > 0.7
                          assign rating_decimal = 1
                        endif
                      %}
                      <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating, rating_max: scale_max }}">
                        <span aria-hidden="true" class="rating-star" style="--rating: {{ value_rating | floor }}; --rating-max: {{ scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
                        {%- capture reviews_label -%}
                          {{ 'products.product.reviews' | t: count: rating_count }}
                        {%- endcapture -%}
                        <p class="rating-count caption">
                          <span aria-hidden="true">{{ rating_count }} {{ reviews_label }}</span>
                          <span class="visually-hidden">{{ rating_count }} {{ "accessibility.total_reviews" | t }}</span>
                        </p>
                      </div>
                      <p class="rating-text">
                        <span aria-hidden="true">{{ rating }} / {{ scale_max }}</span>
                      </p>
                    {%- endif -%}
                  {% endif %}
                </div>
              {%- when 'text' -%}
                <p class="product__vendor uppercase" style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
                  {% if block.settings.show_vendor %}
                    {%- if block.settings.vendor_link -%}
                      <a href="{{ block.settings.vendor_link }}">
                    {%- endif -%}
                    {{ product.vendor }}
                    {%- if block.settings.vendor_link -%}
                      </a>
                    {%- endif -%}
                  {% else %}
                    {{ block.settings.short_description }}
                  {% endif %}
                </p>
              {%- when 'title' -%}
                <h1 class="product__title product-title-style{% if uppercase_product_title == 'all_caps' %} uppercase{% endif %}" style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
                  {{ product.title | escape }}
                </h1>
              {%- when 'price' -%}
                <div class="product__price no-js-hidden" id="price-{{ section.id }}" style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
                  {%- render 'price', product: product, use_variant: true, price_class: 'price--large' -%}
                </div>
                <div class="product-header__info">
                  <div class="product-header__info__text">
                    {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                      <div class="product__tax caption rte">
                        {%- if cart.taxes_included -%}
                          {{ 'products.product.include_taxes' | t }}
                        {%- endif -%}
                        {%- if shop.shipping_policy.body != blank -%}
                          {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                    <div class="product__shop-pay-installments" {{ block.shopify_attributes }}>
                      {%- form 'product', product, id: 'product-form-installment', class: 'installment caption-large'  ,data-loop-product-id:product.id -%}
{% comment %}
  DO NOT modify this source code
  LOOP WIDGET CODE STARTS
{% endcomment %}
{% assign template_exists = false %}
{% capture template_content %}
    {% render 'loop-subscriptions', type: 'product-widget', product: product %}
{% endcapture %}

{% if template_content contains 'Rendering loop-subscriptions' %}
  {% assign template_exists = true %}
{% endif %}

{% if template_exists %}
  {% render 'loop-subscriptions', type: 'product-widget', product: product %}
{% endif %}
{% comment %}
  LOOP WIDGET CODE ENDS
{% endcomment %}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        {{ form | payment_terms }}
                      {%- endform -%}
                    </div>
                  </div>
                </div>
              {%- when 'countdown' -%}
                {% if product.metafields.theme.countdown_date.value != blank %}
                  {%- assign date_end = product.metafields.theme.countdown_date.value | date: '%Y-%m-%d' -%}
                  {%- assign time_end = product.metafields.theme.countdown_date.value | date: '%H:%M' -%}
                  {{ 'section-countdown.css' | asset_url | stylesheet_tag }}
                  <countdown-timer
                    class="{{ block.settings.background }} countdown-timer--hidden"
                    style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};"
                    data-timezone="{{ 'now' | date: '%:z' }}"
                    data-end-date="{{ date_end }}"
                    data-end-time="{{ time_end }}"
                    data-compact="true"
                    data-hide-timer="true"
                  >
                    {% if block.settings.countdown_title != blank %}
                      <div class="countdown__title"><h4>{{ block.settings.countdown_title }}</h4></div>
                    {% endif %}
                    <div class="countdown__timer">
                      <div class="countdown__timer-item">
                        <span data-days-placeholder>00</span>
                        {{ 'general.dateStrings.days' | t }}
                      </div>
                      <div class="countdown__timer-item">
                        <span data-hours-placeholder>00</span>
                        {{ 'general.dateStrings.hours' | t }}
                      </div>
                      <div class="countdown__timer-item">
                        <span data-minutes-placeholder>00</span>
                        {{ 'general.dateStrings.minutes' | t }}
                      </div>
                      <div class="countdown__timer-item">
                        <span data-seconds-placeholder>00</span>
                        {{ 'general.dateStrings.seconds' | t }}
                      </div>
                    </div>
                  </countdown-timer>
                {% endif %}
              {%- when 'custom_liquid' -%}
                {{ block.settings.custom_liquid }}
              {%- when 'variant_picker' -%}
                {% render 'product-variant-picker', block: block, product_form_id: product_form_id, product: product, update_url: true %}
              {%- when 'siblings' -%}
                {% if block.settings.sibling_collection != blank %}
                {% render 'product-siblings', block: block, product: product %}
                {% endif %}
              {%- when 'product_custom_option' -%}
                {% if block.settings.option_name != blank %}
                  {% render 'product-customization-picker', block: block, product_form_id: product_form_id %}
                {% endif %}
              {%- when 'buy_buttons' -%}
                {% liquid
                  assign custom_options = section.blocks | where: 'type', 'product_custom_option'
                  assign custom_file_option = custom_options | map: 'settings' | where: 'type', 'image-upload'
                  assign has_required_option = false
                  for custom_option in custom_options
                    if custom_option.settings.required
                      assign option_type = custom_option.settings.type
                      if option_type == 'single-line' or option_type == 'multi-line'
                        assign has_required_option = true
                        break
                      elsif option_type == 'checkbox'
                        assign checkbox_values = custom_option.settings.values | split: ','
                        if checkbox_values.size > 1 and custom_option.settings.min_selected_options > 0
                          assign has_required_option = true
                          break
                        elsif custom_option.settings.values == blank
                          assign has_required_option = true
                          break
                        endif
                      endif
                    endif
                  endfor

                  if custom_file_option.size > 0
                    assign disallow_dynamic_buttons = true
                  endif
                %}
                {% render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  show_pickup_availability: true,
                  has_required_option: has_required_option,
                  disallow_dynamic_buttons: disallow_dynamic_buttons
                %}
              {%- endcase -%}
            {%- endfor -%}
          </div>
          {% render 'skeleton-text-view' skeleton_layout: 'product-info' %}
        </div>
      </div>
    </div>
  </div>

  {%- if product.media.size > 0 -%}
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if first_3d_model -%}
    <product-modal id="ProductModal-{{ section.id }}" class="product-media-modal media-modal">
      <div class="product-media-modal__dialog" role="dialog" aria-label="{{ 'products.modal.label' | t }}" aria-modal="true" tabindex="-1">
        <button id="ModalClose-{{ section.id }}" type="button" class="product-media-modal__toggle" aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>

        <div class="product-media-modal__content" role="document" aria-label="{{ 'products.modal.label' | t }}" tabindex="0">
          {%- for media in product.media -%}
            {% render 'media', media: media, height: height, image_scale: product_image_scale, media_modal: 'true' %}
          {%- endfor -%}
        </div>
      </div>
    </product-modal>

    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>

    <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {%- endif -%}

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');

        return (msie > 0 || trident > 0);
      }

      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher = document.querySelector('variant-radios[data-section="{{ section.id }}"]') || document.querySelector('variant-selects[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector('.product-form__noscript-wrapper-{{ section.id }}').textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function(event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
  </script>

  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: seo_media.preview_image.width | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

  <template id="quick-buy-content">
    {% render 'quick-shop-drawer', product: product, blocks: section.blocks %}
  </template>
</product-information>

{% schema %}
{
  "name": "t:sections.product-page.name",
  "tag": "section",
  "class": "product-section product-page-section product-static-buy-tools",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "selling_features",
      "name": "t:sections.product-page.blocks.selling_features.name",
      "limit": 1,
      "settings": [
        {
