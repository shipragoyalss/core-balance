{{ 'section-product-content.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-content.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign icon_style = settings.icons_style
  assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo-v, youtube, linkedin' | split: ','

  if product.media.size < 1
    assign hide_gallery = true
  endif
%}

{% unless hide_gallery %}
  <product-content>
{% endunless %}
  <div class="section-{{ section.id }}-padding">
    <div class="product-single__page-wrap page-width page-width--product">
      <div class="product-single__content-details--wrap{% if hide_gallery %} product-single__content-details--wrap--center{% endif %}">
        <div class="product-single__content-details load-skeleton">
          {% render 'skeleton-text-view' skeleton_layout: 'product-details' %}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="product-single__content-details__item" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                  <div class="product-single__description rte">
                    <p>{{ product.description }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- when 'product_features' -%}
              {% assign features_empty = true %}
              {% for i in (1..6) %}
                {% capture feature_title %}feature_title_{{i}}{% endcapture %}
                {% capture feature_text %}feature_text_{{i}}{% endcapture %}
                {% capture feature_custom_icon %}feature_custom_icon_{{i}}{% endcapture %}
                {% capture feature_icon %}feature_icon_{{i}}{% endcapture %}
                {% if block.settings[feature_custom_icon] != blank or block.settings[feature_title] != blank or block.settings[feature_text] != blank %}
                  {% assign features_empty = false %}
                {% endif %}
              {% endfor %}

              {% if features_empty == false %}
                <div class="product-single-features icon-column-section" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                  <ul class="icon-column-section__list">
                    {% for i in (1..6) %}
                      {% capture feature_link %}feature_link_{{i}}{% endcapture %}
                      {% capture feature_image %}feature_image_{{i}}{% endcapture %}
                      {% capture feature_title %}feature_title_{{i}}{% endcapture %}
                      {% capture feature_text %}feature_text_{{i}}{% endcapture %}
                      {% capture feature_custom_icon %}feature_custom_icon_{{i}}{% endcapture %}
                      {% capture feature_icon %}feature_icon_{{i}}{% endcapture %}

                      {% if block.settings[feature_title] != blank %}
                        <li>
                          {%- if block.settings[feature_link] != blank -%}
                            <a href="{{ block.settings[feature_link] }}" class="card-box card-box--vertical {{ block.settings.background }}">
                          {%- else -%}
                            <div class="card-box card-box--vertical {{ block.settings.background }}">
                          {%- endif -%}
                            {%- if block.settings[feature_image] != blank -%}
                              {% assign image = block.settings[feature_image] %}
                              <div class="card-box__image">
                                <div class="media media--transparent media--landscape">
                                  {% assign image_height =  image.width | divided_by: image.aspect_ratio %}
                                  {% assign sizes = "(max-width: 768px) calc(100vw - 1.5rem), (max-width: 1024px) calc((100vw - 1.5rem) / 2), (max-width: 1520px) calc((100vw - 5.5rem) / 3), calc((1520px - 5.5rem) / 3)" %}

                                  {{ image | image_url: width: 990 | image_tag:
                                    loading: 'lazy',
                                    class: 'lazyload',
                                    width: image.width,
                                    height: image_height,
                                    sizes: sizes,
                                    widths: '200, 300, 400, 550, 720, 990',
                                    alt: image.alt | escape
                                  }}
                                </div>
                              </div>
                            {%- endif -%}
                            <div class="card-box__content" style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }}; --icon-scale: {{ block.settings.icon_size | divided_by: 100.0 }};">
                              {% if block.settings[feature_custom_icon] != blank %}
                                <img src="{{ block.settings[feature_custom_icon] | img_url: 'x220' }}" alt="{{ block.settings[feature_title].alt }}" loading="lazy" width="110" height="auto">
                              {% elsif  block.settings[feature_icon] != 'none' %}
                                {% assign brand_icon = brand_icons | where: block.settings[feature_icon] | first %}
                                {% if brand_icon %}
                                  {% assign icon_style = 'fa-brands' %}
                                {% endif %}
                                <i class="icon {{ icon_style }} fa-{{ block.settings[feature_icon] }}"></i>
                              {% endif %}

                              {% if block.settings[feature_title] != blank %}
                                <h2>
                                  {{ block.settings[feature_title] }}
                                </h2>
                              {% endif %}

                              {% if block.settings[feature_text] != blank %}
                                <div class="card-box__text">{{ block.settings[feature_text] }}</div>
                              {% endif %}
                            </div>
                          {%- if block.settings[feature_link] != blank -%}
                            </a>
                          {%- else -%}
                            </div>
                          {%- endif -%}
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            {%- when 'product_notes' -%}
              {% if block.settings.notes_text != blank or block.settings.page != blank %}
                <div class="product-single__content-details__item{% if block.settings.collapsible_content == true %} product-single__content-details__item--collapsible{% endif %}" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                  {% if block.settings.collapsible_content == true %}
                    <details class="product__collapsible-details" id="Details-{{ block.id }}-{{ section.id }}">
                    <summary class="focus-inset" id="Summary-{{ block.id }}-{{ section.id }}">
                      <div class="accordion__sumary-text">
                        <h3>{{ block.settings.notes_title }}</h3>
                      </div>
                      <div class="accordion__icon-open">
                        <i class="icon icon-plus {{ icon_style }} fa-circle-plus"></i>
                        <i class="icon icon-minus {{ icon_style }} fa-circle-minus"></i>
                      </div>
                    </summary>
                  {% endif %}
                  <div class="product-single_fit-notes product__collapsible__content" {% if block.settings.collapsible_content == true %}id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}" role="region" aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"{% endif %}>
                    {% if block.settings.notes_title != blank and block.settings.collapsible_content == false %}
                      <h2>{{ block.settings.notes_title }}</h2>
                    {% endif %}
                    <div class="rte rte-setting">{{ block.settings.notes_text }}</div>
                    {{ block.settings.page.content }}
                  </div>
                  {% if block.settings.collapsible_content == true %}
                    </details>
                  {% endif %}
                </div>
              {% endif %}
            {%- when 'scale' -%}
              {% if block.settings.scale_value != blank %}
                <div class="product-single__content-details__item{% if block.settings.collapsible_content == true %} product-single__content-details__item--collapsible{% endif %}" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                  {% if block.settings.collapsible_content == true %}
                    <details class="product__collapsible-details" id="Details-{{ block.id }}-{{ section.id }}">
                    <summary class="focus-inset" id="Summary-{{ block.id }}-{{ section.id }}">
                      <div class="accordion__sumary-text">
                        <h3>{{ block.settings.scale_title }}</h3>
                      </div>
                      <div class="accordion__icon-open">
                        <i class="icon icon-plus {{ icon_style }} fa-circle-plus"></i>
                        <i class="icon icon-minus {{ icon_style }} fa-circle-minus"></i>
                      </div>
                    </summary>
                  {% endif %}
                  <div class="product__collapsible__content" {% if block.settings.collapsible_content == true %}id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}" role="region" aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"{% endif %}>
                    {% if block.settings.scale_title != blank and block.settings.collapsible_content == false %}
                      <h2>{{ block.settings.scale_title }}</h2>
                    {% endif %}
                    {% if block.settings.scale_text != blank %}
                        <div class="product-single_sheerness--text rte rte-setting">{{ block.settings.scale_text }}</div>
                    {% endif %}
                    <div class="product-single_scale">
                      <div class="product-single_scale-content">
                        {% assign scale_value_number = block.settings.scale_value | plus: 0 %}
                        <div style="left: {{ scale_value_number }}%" class="scale-index"></div>
                      </div>
                      <ul>
                        {% for i in (1..4) %}
                          {% capture scale_label %}scale_label_{{i}}{% endcapture %}
                          {% if block.settings[scale_label] != blank %}
                            <li>{{ block.settings[scale_label] }}</li>
                          {% endif %}
                        {% endfor %}
                      </ul>
                    </div>
                  </div>
                  {% if block.settings.collapsible_content == true %}
                    </details>
                  {% endif %}
                </div>
              {% endif %}
            {%- when 'product_care' -%}
              {% assign care_empty = true %}
              {% for i in (1..6) %}
                {% capture care_text %}care_text_{{i}}{% endcapture %}
                {% capture care_custom_icon %}care_custom_icon_{{i}}{% endcapture %}
                {% if block.settings[care_custom_icon] != blank or block.settings[care_text] != blank %}
                  {% assign care_empty = false %}
                {% endif %}
              {% endfor %}
              {% if care_empty == false %}
                <div class="product-single__content-details__item{% if block.settings.collapsible_content == true %} product-single__content-details__item--collapsible{% endif %}" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                  {% if block.settings.collapsible_content == true %}
                    <details class="product__collapsible-details" id="Details-{{ block.id }}-{{ section.id }}">
                    <summary class="focus-inset" id="Summary-{{ block.id }}-{{ section.id }}">
                      <div class="accordion__sumary-text">
                        <h3>{{ block.settings.care_title }}</h3>
                      </div>
                      <div class="accordion__icon-open">
                        <i class="icon icon-plus {{ icon_style }} fa-circle-plus"></i>
                        <i class="icon icon-minus {{ icon_style }} fa-circle-minus"></i>
                      </div>
                    </summary>
                  {% else %}
                    <h2>{{ block.settings.care_title }}</h2>
                  {% endif %}
                  <ul class="product-single_care-list product__collapsible__content" {% if block.settings.collapsible_content == true %}id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}" role="region" aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"{% endif %}>
                    {% for i in (1..4) %}
                      {% capture care_text %}care_text_{{i}}{% endcapture %}
                      {% capture care_custom_icon %}care_custom_icon_{{i}}{% endcapture %}
                      {% capture care_icon %}care_icon_{{i}}{% endcapture %}
                      {% if block.settings[care_text] != blank %}
                        <li>
                          <span>{{ block.settings[care_text] }}</span>
                          {% if block.settings[care_custom_icon] != blank %}
                            <img src="{{ block.settings[care_custom_icon] | img_url: '60x' }}" alt="{{ block.settings[care_text] }}" width="25" height="auto" loading="lazy">
                          {% elsif block.settings[care_icon] != 'none' %}
                            {% assign brand_icon = brand_icons | where: block.settings[care_icon] | first %}
                            {% if brand_icon %}
                              {% assign icon_style = 'fa-brands' %}
                            {% endif %}
                            <i class="icon {{ icon_style }} fa-{{ block.settings[care_icon] }}"></i>
                          {% endif %}
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                  {% if block.settings.collapsible_content == true %}
                    </details>
                  {% endif %}
                </div>
              {% endif %}
            {%- when 'size_chart' -%}
              <div class="product-single__content-details__item{% if block.settings.collapsible_content == true %} product-single__content-details__item--collapsible{% endif %}" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                {% if block.settings.collapsible_content == true %}
                  <details class="product__collapsible-details" id="Details-{{ block.id }}-{{ section.id }}">
                  <summary class="focus-inset" id="Summary-{{ block.id }}-{{ section.id }}">
                    <div class="accordion__sumary-text">
                      <h3>{{ block.settings.chart_title }}</h3>
                    </div>
                    <div class="accordion__icon-open">
                      <i class="icon icon-plus {{ icon_style }} fa-circle-plus"></i>
                      <i class="icon icon-minus {{ icon_style }} fa-circle-minus"></i>
                    </div>
                  </summary>
                {% endif %}
                <div class="product__collapsible__content" {% if block.settings.collapsible_content == true %}id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}" role="region" aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"{% endif %}>
                  {% if block.settings.chart_title != blank and block.settings.collapsible_content == false %}
                    <h2>{{ block.settings.chart_title }}</h2>
                  {% endif %}
                  {% assign counter = 0 %}
                  {% for i in (1..5) %}
                    {% capture row_name_i %}row_name_{{i}}{% endcapture %}
                    {% capture column_values_i %}column_values_{{i}}{% endcapture %}
                    {% if block.settings[row_name_i] != blank and block.settings[column_values_i] != blank %}
                      {% assign counter = counter | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                  {% render 'size-chart', rows: block, counter: counter %}
                  {%- if block.settings.note != blank -%}
                    <p class="section-size-chart__note">* {{ block.settings.note }}</p>
                  {%- endif -%}
                </div>
                {% if block.settings.collapsible_content == true %}
                    </details>
                {% endif %}
              </div>
            {%- when 'share' -%}
              <div class="product-single__content-details__item" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
                {% render 'social-sharing' share_facebook: block.settings.share_facebook, share_twitter: block.settings.share_twitter, share_pinterest: block.settings.share_pinterest, , share_permalink: product.url, share_title: product.title, share_image: product.featured_image %}
              </div>
            {%- when 'checklist' -%}
              <div class="product-single__content-details__item" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;">
                <quality-checklist>
                  <div class="checklist-wrap {{ block.settings.background }} {{ block.settings.font_type }}" style="--font-section-scale: {{ block.settings.font_size | divided_by: 100.0 }};">
                    <div class="checklist-wrap__image">
                      {% if block.settings.image != blank %}
                        <div class="media media--transparent" {%- if block.settings.show_scrim -%} style="--scrim-lightness: {{ block.settings.scrim_lightness }}, {{ block.settings.scrim_lightness }}, {{ block.settings.scrim_lightness }}"{%- endif -%}>
                          {% assign image_height =  block.settings.image.width | divided_by: block.settings.image.aspect_ratio %}
                          {% assign sizes = "(max-width: 768px) calc(100vw - 1.5rem), (max-width: 1024px) calc((100vw - 1.5rem) / 2), (max-width: 1520px) calc((100vw - 5.5rem) / 3), calc((1520px - 5.5rem) / 3)" %}

                          {{ block.settings.image | image_url: width: 540 | image_tag:
                            loading: 'lazy',
                            width: block.settings.image.width,
                            height: image_height,
                            sizes: sizes,
                            widths: '200, 300, 400, 540',
                            alt: block.settings.image.alt | escape
                          }}
                        </div>
                      {% endif %}
                      {% if block.settings.text != blank %}
                        <h3 class="h2">{{ block.settings.text }}</h3>
                      {% elsif block.settings.icon != 'none' %}
                        {% assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo, youtube' | split: ',' %}
                        {% assign brand_icon = brand_icons | where: block.settings.icon | first %}
                        {% if brand_icon %}
                          {% assign icon_style = 'fa-brands' %}
                        {% endif %}
                        <i class="icon {{ icon_style }} fa-{{ block.settings.icon }}"></i>
                      {% endif %}
                    </div>
                    <ul>
                      {% for i in (1..4) %}
                        {% capture text %}text_{{i}}{% endcapture %}
                        {% capture icon %}icon_{{i}}{% endcapture %}
                        {% if block.settings[text] != blank %}
                          <li>
                            {% if block.settings[icon] != 'none' %}
                              {% assign brand_icons = 'facebook, instagram, pinterest, snapchat, tiktok, tumblr, twitter, vimeo, youtube' | split: ',' %}
                              {% assign brand_icon = brand_icons | where: block.settings[icon] | first %}
                              {% if brand_icon %}
                                {% assign icon_style = 'fa-brands' %}
                              {% endif %}
                              <i class="icon {{ icon_style }} fa-{{ block.settings[icon] }}"></i>
                            {% endif %}
                            <span class="checklist__line-text h4">{{ block.settings[text] }}</span>
                          </li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                </quality-checklist>
              </div>
            {%- when 'complementary' -%}
              <div class="product-single__content-details__item" style="--padding-top: {{ block.settings.padding_top }}px; --padding-bottom: {{ block.settings.padding_bottom }}px;">
                <product-recommendations class="complementary-products no-js-hidden" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary">
                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    <div aria-label="{{ 'accessibility.complementary_products' | t }}" {{ block.shopify_attributes }}>
                      <div class="complementary-products__container">
                        <h2>{{ block.settings.block_heading }}</h2>
                        {% render 'complementary-products' product: product, block: block %}
                      </div>
                    </div>
                  {%- endif -%}
                </product-recommendations>
                {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
              </div>
            {%- when 'custom_liquid' -%}
              {{ block.settings.custom_liquid }}
            {%- when '@app' -%}
              <div class="product-single__content-details__item" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{% unless hide_gallery %}
  </product-content>
{% endunless %}

{% schema %}
{
  "name": "t:sections.product-content.name",
  "tag": "section",
  "class": "product-section product-content-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.product-content.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing.section_spacing_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.spacing.spacing_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "description",
      "name": "t:sections.product-content.blocks.description.name",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.all.spacing.block_spacing_heading"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "t:sections.all.spacing.spacing_top",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "t:sections.all.spacing.spacing_bottom",
          "default": 50
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "t:sections.product-content.blocks.custom_liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.product-content.blocks.custom_liquid.settings.custom_liquid.label",
          "info": "t:sections.product-content.blocks.custom_liquid.settings.custom_liquid.info"
        }
      ]
    },
    {
      "type": "product_features",
      "name": "t:sections.product-content.blocks.product_features.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "To show different content for each product, use Metafields. [Learn more](https://archer-commerce.helpscoutdocs.com/article/50-product-features)"
        },
        {
          "type": "paragraph",
          "content": "t:sections.product-content.blocks.product_features.settings.paragraph.content"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "t:sections.all.font_size.label",
          "default": 100,
          "min": 80,
          "max": 120,
          "unit": "%",
          "step": 1
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "t:sections.feature-cards.settings.icon_size.label",
          "default": 100,
          "min": 30,
          "max": 230,
          "unit": "%",
          "step": 2
        },
        {
          "type": "select",
          "id": "background",
          "label": "t:sections.all.colors.label",
          "options": [
            {
              "value": "main-background",
              "label": "t:sections.all.colors.background_1.label"
            },
            {
              "value": "alt-background",
              "label": "t:sections.all.colors.background_2.label"
            },
            {
              "value": "alt-background-2",
              "label": "t:sections.all.colors.background_3.label"
            },
            {
              "value": "alt-background-3",
              "label": "t:sections.all.colors.background_4.label"
            },
            {
              "value": "background-modal",
              "label": "t:sections.all.colors.background_5.label"
            }
          ],
          "default": "background-modal"
        },
        {
          "type": "header",
          "content": "t:sections.product-content.blocks.product_features.settings.header_1.content"
        },
        {
          "type": "image_picker",
          "id": "feature_image_1",
          "label": "t:sections.product-content.blocks.product_features.settings.feature_image.label",
          "info": "t:sections.product-content.blocks.product_features.settings.feature_image.info"
        },
        {
          "type": "text",
          "id": "feature_title_1",
          "label": "t:sections.product-content.blocks.product_features.settings.feature_title.label",
          "default": "Easy Care"
        },
        {
          "type": "select",
          "id": "feature_icon_1",
          "options": [
            {
              "value": "none",
              "label": "t:general.icons-theme.options__1.label"
            },
            {
              "group": "Basic icons",
              "label": "t:general.icons-theme.options__2.label",
              "value": "user"
            },
            {
              "group": "Basic icons",
              "label": "Arrow down to bracket",
              "value": "arrow-down-to-bracket"
            },
            {
              "group": "Basic icons",
              "label": "Arrow left",
              "value": "arrow-left"
            },
            {
              "group": "Basic icons",
              "label": "Arrow right arrow left",
              "value": "arrow-right-arrow-left"
            },
            {
              "group": "Basic icons",
              "label": "Arrow right",
              "value": "arrow-right"
            },
            {
              "group": "Basic icons",
              "label": "Arrow up right from square",
              "value": "arrow-up-right-from-square"
