<ul class="list--inline site-footer__social-icons social-icons site-footer__icon-list">
                      {%- if settings.social_twitter_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_twitter_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-twitter"></i>
                            <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_facebook_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_facebook_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-facebook"></i>
                            <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_pinterest_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_pinterest_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-pinterest"></i>
                            <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_instagram_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_instagram_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-instagram"></i>
                            <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_tiktok_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_tiktok_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-tiktok"></i>
                            <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_tumblr_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_tumblr_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-tumblr"></i>
                            <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_snapchat_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_snapchat_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-snapchat"></i>
                            <span class="visually-hidden">{{ 'general.social.links.snapchat' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_youtube_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_youtube_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-youtube"></i>
                            <span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if settings.social_vimeo_link != blank -%}
                        <li class="social-icons__item">
                          <a href="{{ settings.social_vimeo_link }}" class="social-icons__link">
                            <i class="icon fa-brands fa-vimeo"></i>
                            <span class="visually-hidden">{{ 'general.social.links.vimeo' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if request.page_type == 'blog' or request.page_type == 'article' -%}
                        <li class="social-icons__item">
                          <a class="social-icons__link" href="{{ shop.url }}{{ blog.url }}.atom">
                            <i class="icon {{ icon_style }} fa-rss"></i>
                            <span class="icon__fallback-text">RSS</span>
                          </a>
                        </li>
                      {%- endif -%}
                    </ul>