          {
            $("#btn_createdraftorder").text("CREATE DRAFT ORDER");
          }
          
          $("#customerSelectionError").text("Please fill all address fields.");
          $("#customerSelectionError").css("color", "#f80000");
          $("#customerSelectionError").show();
       return false;
     }
    }
  }
 
  var GetShippingRatesofSelectedAddress = function()
 {
   var customerAddrs = $('#custAddresses').val();
   var customerzip,customercountry,customerprovince;
    try
    {  
    if(isSelectShippingCostFeatureOn)
    {
     if(IsAddNewAddressDivOpenFlag == true)
     {
       if((($('#customer_country').val()) != ""|| (isNaN($('#customer_country').val()))) && (($('#country_zip').val()) != ""|| (isNaN($('#country_zip').val()))) && (($('#statedd').val()) != ""|| (isNaN($('#statedd').val()))))
       { 
         customerzip = $('#customer_country').val();
       	 customercountry = $('#country_zip').val();
         customerprovince = $('#statedd').val();
      	}
     }
  	 else
     {
      var i;
      if(customerAddrs != null)
      {
      for (i = 0; i < getCustomerAddressData.length; i++) 
      {
        if(getCustomerAddressData[i].id == customerAddrs)
        {
          shippingrates=[];
          customerzip = getCustomerAddressData[i].zip;
          customercountry = getCustomerAddressData[i].country;
          customerprovince = getCustomerAddressData[i].province;
          
        }
       }
      }
     }
      
      $.ajax({
			 type: 'POST',
			 url: '/cart/prepare_shipping_rates.json?shipping_address[zip]='+customerzip+'&shipping_address[country]='+customercountry+'&shipping_address[province]='+customerprovince+'',
			 success: function (res) {
			 console.log("res",res);
          
         $.ajax({
			 type: 'GET',
			 url: '/cart/async_shipping_rates.json?shipping_address[zip]='+customerzip+'&shipping_address[country]='+customercountry+'&shipping_address[province]='+customerprovince+'',
			 success: function (res1) {
			 console.log("res1",res1);
               shippingrates = res1;
               showShipingRatesInDropDown(res1);
			 }
			 });
               
             },
             error: function (err){
               	$("#customerSelectionError").text("There was a problem calculating your shipping rates.");
          		$("#customerSelectionError").css("color", "#f80000");
          		$("#customerSelectionError").show();                
        	}
      });
    }
    }
    catch(ex)
    {
                $("#customerSelectionError").text("Something went wrong please try again.");
     
    }
 }
  
 var showShipingRatesInDropDown = function(shippingRatesArray)
 {
   var i;
   for (i=0;i<shippingRatesArray.shipping_rates.length;i++) 
   {
   		$('#ShippingRates').append('<option name='+ shippingRatesArray.shipping_rates[i].name +' value='+ shippingRatesArray.shipping_rates[i].price +'> '+shippingRatesArray.shipping_rates[i].name+' / '+shippingRatesArray.shipping_rates[i].price+'</option>');
   }
   
 }
 var checkFilteredString = function(inputString)
 {
 return (inputString != undefined && inputString != null && inputString != '') ? inputString : "";
 }
