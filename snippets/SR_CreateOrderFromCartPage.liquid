 var getCustAddresses = function(setCustomerAddressData)
  {
    var customerAddrs = $('#custAddresses').val();
      
    //$('#custAddresses').empty();
    if(IsAddNewAddressDivOpenFlag == true)
    {
       if((($('#customer_address1').val()) != ""|| (isNaN($('#customer_address1').val()))) && (($('#customer_city').val()) != ""|| (isNaN($('#customer_city').val()))) && (($('#customer_country').val()) != ""|| (isNaN($('#customer_country').val()))) && (($('#country_zip').val()) != ""|| (isNaN($('#country_zip').val()))) && (($('#customer_firstName').val()) != ""|| (isNaN($('#customer_firstName').val()))) && (($('#customer_lastName').val()) != ""|| (isNaN($('#customer_lastName').val()))) && (($('#phoneNumber').val()) != ""|| (isNaN($('#phoneNumber').val()))))
       { 
         var toggleFirstName = $('#customer_firstName').val();
         var toggleLastName = $('#customer_lastName').val();
         var togglePhn = $('#phoneNumber').val();
         var toggleaddress1 = $('#customer_address1').val();
         var toggleCompany = $('#customer_company').val();
       	 var toggleCity = $('#customer_city').val();
       	 var toggleCountry = $('#customer_country').val();
       	 var toggleZip = $('#country_zip').val();
         var togglePhn = $('#phoneNumber').val();
      	
         setCustomerAddressData.push({
                  "fname" :toggleFirstName, 
                  "lastname" :toggleLastName,
                  "phone" : togglePhn,
                  "address1" :toggleaddress1,
           		  "company" : toggleCompany,
                  "city" :toggleCity,
                  "country" : toggleCountry,
                  "zip" : toggleZip
               });
         
         isNewAddress = true;
         return true;
      	}
     	else
     	{
        	if(isCreateOrderFeatureOn)
          {
            $("#btn_createdraftorder").text("CREATE ORDER");
          }
          else
          {
            $("#btn_createdraftorder").text("CREATE DRAFT ORDER");
          }
          $("#customerSelectionError").text("Please select Address and try again.");
       		$("#customerSelectionError").css("color", "#f80000");
            $("#customerSelectionError").show();
       		return false;
     	}
  	}
  else
    {
      var i;
      if(customerAddrs != null && customerAddrs != "")
      {
      for (i = 0; i < getCustomerAddressData.length; i++) {
        if(getCustomerAddressData[i].id == customerAddrs)
        {
          setCustomerAddressData.push({
            	  "fname" : getCustomerAddressData[i].first_name, 
                  "lastname" : getCustomerAddressData[i].last_name,
                  "phone" : getCustomerAddressData[i].phone1,
                  "address1" :getCustomerAddressData[i].address1,
                  "city" :getCustomerAddressData[i].city,
                  "province" :getCustomerAddressData[i].province,
                  "country" : getCustomerAddressData[i].country,
                  "zip" : getCustomerAddressData[i].zip
                });
        }
      }
       isNewAddress = false;
       return true;
     }
     else
     {
       if(isCreateOrderFeatureOn)
          {
            $("#btn_createdraftorder").text("CREATE ORDER");
