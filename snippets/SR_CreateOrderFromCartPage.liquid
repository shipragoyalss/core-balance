  var getAddressesOfSelectedCustomer = function()
  {
    if(isSelectAdreesFromDropDownFeatureOn)
    { 
    $('#custAddresses').empty();
  	$('#custAddresses').append('<option value=""> Loading . . . </option>');
    var customerId =CustomerId;
    var urlVal=window.location.protocol +"//"+ window.location.hostname +"/apps/SalesRep?customerId="+customerId+"&data=31";
            $.get(
              urlVal,
              function (response, status) 
              {
                getCustomerAddressData = response.customerAddressesList;
                $('#custAddresses').empty();
     			$('#custAddresses').append('<option value=""> Select Address </option>');  
                for(var addr in response.customerAddressesList)
                {
                  if(response.customerAddressesList[addr].address1 != null){ var address1 = response.customerAddressesList[addr].address1; }else{ address1 = '' }
                  if(response.customerAddressesList[addr].city!= null){ var city = response.customerAddressesList[addr].city;}else{ city = ''}
                  if(response.customerAddressesList[addr].province != null){ var province = response.customerAddressesList[addr].province;}else{ province = ''}
                  if(response.customerAddressesList[addr].country != null){ var country = response.customerAddressesList[addr].country;}else{ country = ''}
                  if(response.customerAddressesList[addr].zip != null){ var zip = response.customerAddressesList[addr].zip;}else{ zip = ''}
                  
                  $('#custAddresses').append('<option name='+ response.customerAddressesList[addr].id +' value='+ response.customerAddressesList[addr].id +'> '+ address1 +' '+ city +' '+ province +' '+ country +' '+ zip +'</option>');              
                  
                }
              });
    $('#custAddresses').change();
  }
  }
  
 function onChangeCountryDD()
 {
   $('#statedd').find('option').not(':first').remove();
   var stateArray = $('#customer_country option:selected').attr("data-provinces"); //JSON.parse($('#customer_country option:selected').attr("data-provinces"));
   var parsedStateArray = stateArray != undefined && stateArray != null ? JSON.parse(stateArray) : [];
   var states = "";
   for(var state in parsedStateArray)
    {
     states += '<option value="'+parsedStateArray[state][0]+'">'+ parsedStateArray[state][0]+ '</option>';
    }
   $('#statedd').append(states);
 }
  
 var createDraftOrder = function()
    {  
      event.preventDefault();
      $("#customer_error").hide();
      var sr_customer_email= checkFilteredString(CustomerEmail);
      var sr_customer_fname= checkFilteredString(CustomerId);
      var cust_addr = $("#custAddresses option:selected").val();
      var completeDraftOrderStatus = false;
      var setCustomerAddressData = [];
      var shippingName = null;
      var shippingCost = null;   
      $("#btn_createdraftorder").prop('disabled', true);
        if(isCreateOrderFeatureOn)
        {
          completeDraftOrderStatus = true;
        }
        if(isSelectAdreesFromDropDownFeatureOn)
        {
          var addressSelected = getCustAddresses(setCustomerAddressData);
        }
        if(isSelectShippingCostFeatureOn)
        {
          if($("#ShippingRates option:selected").attr("name") != "" && $("#ShippingRates option:selected").val() != "")
          {
          	shippingName = $("#ShippingRates option:selected").attr("name");
   		  	shippingCost = $("#ShippingRates option:selected").val();
          }
        }
        if(sr_customer_fname == "" || sr_customer_email=="")
        {
          
          $("#customerSelectionError").text("No Customer Selected. Please select customer and try again.");
          $("#customerSelectionError").css("color", "#f80000");
          $("#customerSelectionError").show();
           $("#btn_createdraftorder").prop('disabled',false);
        }
        else
        {
          $("#customerSelectionError").hide(); 
  		
          $("#btn_createdraftorder").text("CREATING ORDER...");
           GetCartData();
            var prods = JSON.stringify(ClientInvoiceselectedProduct);
             if(ClientInvoiceselectedProduct.length<1)
             {
               $("#btn_createdraftorder").text("Check out");
               $("#btn_createdraftorder").prop('disabled', false);
               $("#customerSelectionError").text('No Products Selected. Please select products and try again.');  
               $("#customerSelectionError").css("color", "#f80000");
               $("#customerSelectionError").show();
             }
          	 else
             { 
                var order = {
                  "email" : "{{customer.email}}",
                  "prods" : prods,
                  "customerId" : "{{customer.id}}",
                  "wholesale": "false",
                  "Index": "-1",
                  "custId" : sr_customer_fname,
                  "cusemail": sr_customer_email,
                  "pro":  false,
                  "cusAddress":setCustomerAddressData,
                  "propertiesArr" : allLineItemProperties,
                  "completeDraftOrder":completeDraftOrderStatus,
                  "shippingtitle":shippingName,
          		  "shippingprice":shippingCost,
                  "isNewaddress": isNewAddress
                }
                var customerdata = JSON.stringify(order);
                var urlVal=window.location.protocol +"//"+ window.location.hostname +"/apps/SalesRep?pageIndex=0";
                $.ajax({
                  url : urlVal,
                  type : "post",
                  headers: {
        				"Content-Type": "application/json"
    				},
                  data: customerdata,
                  dataType: "json",
                  success : function(data, status) {           
                         createDraftOrderFromCartPageResponseSuccess(data, status);
                         $("#btn_createdraftorder").prop('disabled', false);
                      }
                  });
                }
        }
      }
 
 var GetCartData = function()
        {         
            var CartData = [];  
          	var item_count = {{cart.item_count}}
          
        	{% for line in cart.items %}
                var price = ({{line.variant.price | amount_no_decimals  }})/100;
                var total_price = ({{line.final_line_price | amount_no_decimals  }})/100;
          
          		var variant = [];
                var propertiesObj = {};
                var propertiesArr =[];
          
          		variant.push({
                  "price":price,
                  "id":'{{line.variant_id}}'
                });
          

                {% for property in line.properties %}
                propertiesArr.push({
                    "name" : '{{ property | first }}',
                    "value" : '{{ property | last | replace: '&quot;', '\"' | replace: '&amp;', '&' }}'
                    });
    			{% endfor %}
          
          allLineItemProperties.push({
            "variantId": '{{line.variant_id}}', 
             "variantProperties": propertiesArr 
          });
                
                CartData.push({
                "Image":'{{ line.image | product_img_url: '100x100' }}',
                "title":'{{line.title}}',
                "product_quantity":{{line.quantity}},
                "Item_Price":price.toString(),
                "product_price":total_price,
                "product_type":'{{line.product.type}}',
                "variantId":'{{line.variant_id}}',
                "product_size":"{{line.variant.option1}}",
                "handle":'{{line.product.handle}}',
                "count":{{cart.item_count}},
                "variants": variant
              });
          	{%endfor%}
          
          
          if(item_count != 0 )
          {
          	for(var data in CartData)
            {
                ClientInvoiceselectedProduct.push({
                  "variantId" :CartData[data].variantId, 
                   "quantity" :CartData[data].product_quantity,
                   "product_type" :CartData[data].product_type,
                   "price" : CartData[data].Item_Price,
                   "Image" : CartData[data].Image
                });
            } 
          }          
        }
 
