{% comment %}
    Renders facets (filtering and sorting)

    Accepts:
    - results: {Object} Collection or Search object
    - enable_filtering: {Boolean} Show filtering when true
    - page: {int} Current page

    Usage:
    {% render 'facets', results: collection, enable_sorting: true %}
{% endcomment %}

{%- liquid
  assign icon_style = settings.icons_style
  assign sort_by = results.sort_by | default: results.default_sort_by
  assign total_active_values = 0
  if results.url
    assign results_url = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  assign active_filters = false
  for filter in results.filters
    if filter.active_values.size > 0
      assign active_filters = true
    endif
  endfor
-%}

<div class="facets-container">
  <facet-filters-form class="facets small--hide">
    <form id="FacetFiltersForm" class="facets__form">
      {%- if results.terms -%}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
        <input name="options[prefix]" type="hidden" value="last">
      {%- endif -%}

      {% if enable_filtering %}
        <div id="FacetsWrapperDesktop">
          {%- if results.filters != empty -%}
            <div class="facets__heading-wrap">
              <h2 class="facets__heading" id="verticalTitle" tabindex="-1">{{ 'products.facets.filter_by_label' | t }}</h2>
              <div class="facet-filters__clear-filters" data-clear-filter="0">
                {%- if active_filters == true and enable_sorting != true -%}
                  <facet-remove class="active-facets__button-wrapper">
                    <a href="{{ results_url }}" class="active-facets__button-remove">
                      <span>{{ 'products.facets.clear_all' | t }}</span>
                      <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
                    </a>
                  </facet-remove>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <div class="facets__filters-parent">
            <div class="facets__filters-wrap" {% if results.filters.size < 4 %}style="--filter-columns-number: {{ results.filters.size }}"{% endif %}>
              {%- for filter in results.filters -%}
                {%- assign total_active_values = total_active_values | plus: filter.active_values.size -%}
                {% case filter.type %}
                {% when 'boolean' or 'list' %}
                  <div id="Wrap-Filter-{{ filter.label | handleize }}-{{ forloop.index }}" class="facets__filters__column js-filter{% if forloop.index > 4 %} hidden{% endif %}" data-index="{{ forloop.index }}">
                    <details id="Details-{{ forloop.index }}-{{ section.id }}" class="facets__filters__details disclosure-has-popup facets__disclosure background-modal">
                      <summary class="facets__summary" aria-label="{{ filter.label }} ({{ 'products.facets.filters_selected.one' | t: count: filter.active_values.size }})">
                        <div class="facets__summary__text">
                          <span>{{ filter.label | escape }}</span>
                          <i class="icon icon-chevron-down {{ icon_style }} fa-chevron-down" style="--fa-secondary-opacity: 1;"></i>
                        </div>
                      </summary>
                      <div id="Facet-{{ forloop.index }}-{{ section.id }}" class="parent-display facets__display">
                        <fieldset class="facets-wrap parent-wrap background-alt">
                          <legend class="visually-hidden">{{ filter.label | escape }}</legend>
                          <ul class="list-unstyled" role="list">
                            {%- for value in filter.values -%}
                              <li class="list-menu__item facets__item">
                                <input
                                  id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}checked{% endif %}
                                  {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                                <label
                                  for="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                                  class="facet-checkbox{% if value.count == 0 and value.active == false %} facet-checkbox--disabled{% endif %}">
                                  <span class="input-check-mark"><i class="icon-check {{ icon_style }} fa-check"></i></span>
                                  <span class="facet-checkbox__text" aria-hidden="true">{{ value.label | escape }} ({{ value.count }})</span>
                                  <span class="visually-hidden">{{ value.label | escape }} ({% if value.count == 1 %}{{ 'products.facets.product_count_simple.one' | t: count: value.count }}{% else %}{{ 'products.facets.product_count_simple.other' | t: count: value.count }}{% endif %})</span>
                                </label>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </fieldset>
                      </div>
                    </details>
                    <div id="Active-Facet-{{ forloop.index }}" class="active-facets">
                      {%- for value in filter.active_values -%}
                        <facet-remove>
                          <a href="{{ value.url_to_remove }}" class="active-facets__button active-facets__button--light">
                            <span class="active-facets__button-inner background-modal">
                              {{ value.label | escape }}
                              <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
                              <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                            </span>
                          </a>
                        </facet-remove>
                      {%- endfor -%}
                    </div>
                  </div>
                {% when 'price_range' %}
                  {% liquid
                    assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                    assign uses_comma_decimals = false
                    if currencies_using_comma_decimals contains cart.currency.iso_code
                      assign uses_comma_decimals = true
                    endif
                  %}
                  <div id="Wrap-Filter-{{ filter.label | handleize }}-{{ forloop.index }}" class="facets__filters__column js-filter{% if forloop.index > 4 %} hidden{% endif %}" data-index="{{ forloop.index }}">
                    <details id="Details-{{ forloop.index }}-{{ section.id }}" class="facets__filters__details disclosure-has-popup facets__disclosure background-modal">
                      <summary class="facets__summary">
                        <div class="facets__summary__text">
                          <span>{{ filter.label | escape }}</span>
                          <i class="icon icon-chevron-down {{ icon_style }} fa-chevron-down" style="--fa-secondary-opacity: 1;"></i>
                        </div>
                      </summary>
                      <div id="Facet-{{ forloop.index }}-{{ section.id }}" class="facets__display parent-display">
                        <div class="facets-wrap facets-wrap--price background-alt">
                          <div class="facets__header">
                            {%- assign max_price_amount = filter.range_max | money | strip_html | escape -%}
                            <facet-remove>
                              <a href="{{ filter.url_to_remove }}" class="facets__reset">
                                {{ 'products.facets.reset' | t }}
                              </a>
                            </facet-remove>
                          </div>
                          <price-range class="facets__price">
                            <div class="field-wrapper">
                              <span class="field-currency">{{ cart.currency.symbol }}</span>
                              <input class="field-wrapper__input filter__price__input"
                                name="{{ filter.min_value.param_name }}"
                                id="Filter-{{ filter.label | escape }}-GTE"
                                {%- if filter.min_value.value -%}
                                  {%- if uses_comma_decimals -%}value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                {%- endif -%}
                                type="number"
                                placeholder="0"
                                min="0"
                                {%- if uses_comma_decimals -%}max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"{% endif %}
                              >
                              <label class="field-wrapper__label" for="Filter-{{ filter.label | escape }}-GTE">
                                <span class="field-wrapper__label-name">{{ 'products.facets.from' | t }}</span>
                              </label>
                            </div>
                            <div class="field-wrapper">
                              <span class="field-currency">{{ cart.currency.symbol }}</span>
                              <input class="field-wrapper__input filter__price__input"
                                name="{{ filter.max_value.param_name }}"
                                id="Filter-{{ filter.label | escape }}-LTE"
                                {%- if filter.max_value.value -%}{%- if uses_comma_decimals -%}value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                {%- endif -%}
                                type="number"
                                min="0"
                                {%- if uses_comma_decimals -%}
                                  placeholder="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                                  max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                                {%- else -%}
                                  placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                  max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                {% endif %}
                              >
                              <label class="field-wrapper__label" for="Filter-{{ filter.label | escape }}-LTE">
                                <span class="field-wrapper__label-name">{{ 'products.facets.to' | t }}</span>
                              </label>
                            </div>
                            <p class="requirement-form">
                              {{ "products.facets.max_price" | t: price: max_price_amount }}
                            </p>
                          </price-range>
                        </div>
                      </div>
                    </details>
                    <div id="Active-Facet-{{ forloop.index }}" class="active-facets">
                      {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
                        <facet-remove>
                          <a href="{{ filter.url_to_remove }}" class="active-facets__button active-facets__button--light">
                            <span class="active-facets__button-inner background-modal">
                              {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}-{%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                              <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
                              <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                            </span>
                          </a>
                        </facet-remove>
                      {%- endif -%}
                    </div>
                  </div>
                {% endcase %}
              {%- endfor -%}
              <noscript style="padding: 0 10px;">
                <button type="submit" class="facets__button-no-js btn btn--light-3 btn--secondary btn--small">{{ 'products.facets.filter_button' | t }}</button>
              </noscript>
            </div>
            <div class="facets__add-more{% unless enable_sorting %} facets__add-more--no-margin{% endunless %}">
              {%- if results.filters.size > 4 -%}
                <details class="facets__filters__details disclosure-has-popup facets__disclosure background-modal">
                  <summary class="facets__summary" aria-label="{{ 'products.facets.add_filter_label' | t }}">
                    <div class="facets__summary__text">
                      <span><i class="{{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i> {{ 'products.facets.add_filter_label' | t }}</span>
                    </div>
                  </summary>
                  <div class="parent-display facets__display">
                    <fieldset class="facets-wrap parent-wrap background-alt">
                      <legend class="visually-hidden">{{ 'products.facets.add_filter_label' | t }}</legend>
                      <ul class="list-unstyled no-js-hidden" role="list">
                        {%- for filter in results.filters -%}
                          {% if forloop.index > 4 %}
                            <li class="list-menu__item facets__item">
                              <input
                                id="Add-Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                                class="facets__add-filter"
                                type="checkbox"
                                name="{{ filter.label | escape }}"
                                value="{{ filter.label | handleize }}"
                                data-index="{{ forloop.index }}"
                                data-url="{{ filter.url_to_remove }}"
                                {% if forloop.index < 5 %}checked{% endif %}>
                              <label
                                for="Add-Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                                class="facet-checkbox">
                                <span class="input-check-mark"><i class="icon icon-check {{ icon_style }} fa-check"></i></span>
                                <span class="facet-checkbox__text" aria-hidden="true">{{ filter.label | escape }}</span>
                                <span class="visually-hidden">{{ filter.label | escape }}</span>
                              </label>
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    </fieldset>
                  </div>
                </details>
              {%- endif -%}
            </div>
          </div>
        </div>
      {% endif %}

      {% if results.current_vendor or results.current_type %}
        <input type="hidden" name="q" value="{{ results.current_vendor }}{{ results.current_type }}">
      {% endif %}

      {%- if results.terms -%}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
      {%- endif -%}

      {%- if enable_sorting -%}
        <div class="facet-filters">
          <div class="facet-filters__clear-filters" data-clear-filter="1">
            {%- if active_filters == true -%}
              <facet-remove class="active-facets__button-wrapper{% unless enable_filtering %} hidden{% endunless %}">
                <a href="{{ results_url }}" class="active-facets__button-remove">
                  <span>{{ 'products.facets.clear_all' | t }}</span>
                  <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
                </a>
              </facet-remove>
            {%- else -%}
              <div style="margin-bottom: 0.5625rem;height:1.125rem;"></div>
            {%- endif -%}
          </div>

          <div class="facet-filters__field facet-filters__sort">
            {%- assign sort_by = results.sort_by | default: results.default_sort_by -%}
            <details id="Sort-Details-{{ section.id }}" class="facets__filters__details disclosure-has-popup facets__disclosure background-modal">
              <summary class="facets__summary" aria-label="{{ 'products.facets.sort_by_label' | t }}">
                {% assign selected_sort = results.sort_options | where: 'value', sort_by | first %}
                <i class="icon icon-chevron-down {{ icon_style }} fa-chevron-down" style="--fa-secondary-opacity: 1;"></i>
                <div class="facets__summary__text{% if selected_sort %} facets__summary__text--label{% endif %}">
                  <span>{{ 'products.facets.sort_by_label' | t }}</span>
                </div>
                {% if selected_sort %}
                  <span class="facet-filters__selected-sort">{{ selected_sort.name }}</span>
                {% endif %}
              </summary>
              <div id="Facet-{{ forloop.index }}-{{ section.id }}" class="parent-display facets__display">
                <fieldset class="facets-wrap parent-wrap background-alt">
                  <legend class="visually-hidden">{{ 'products.facets.sort_by_label' | t }}</legend>
                  <ul class="list-unstyled" role="list">
                    {%- for option in results.sort_options -%}
                      <li class="list-menu__item facets__item">
                        <input
                          id="Sort-{{ 'products.facets.sort_by_label' | t }}-{{ forloop.index }}"
                          type="radio"
                          name="sort_by"
                          value="{{ option.value | escape }}"
                          data-sort-name="{{ option.name | escape }}"
                          {% if option.value == sort_by %}checked{% endif %}>
                        <label
                          for="Sort-{{ 'products.facets.sort_by_label' | t }}-{{ forloop.index }}"
                          class="facet-checkbox">
                          <span class="input-check-mark"></span>
                          <span class="facet-checkbox__text" aria-hidden="true">{{ option.name | escape }}</span>
                          <span class="visually-hidden">{{ option.name | escape }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                </fieldset>
              </div>
            </details>
            <noscript>
              <button type="submit" class="facets__button-no-js btn btn--light-3 btn--secondary btn--smal">{{ 'products.facets.sort_button' | t }}</button>
            </noscript>
          </div>
        </div>
      {%- endif -%}

      {%- if page -%}
        <input name="page" type="hidden" value="{{ page }}">
      {%- endif -%}
    </form>
  </facet-filters-form>

  {% comment %}  Drawer and mobile filter {% endcomment %}
  <div class="facet-filters__clear-filters" data-clear-filter="2">
  {%- if active_filters == true -%}
    <facet-remove class="active-facets__button-wrapper medium--hide large-up--hide{% unless enable_filtering %} hidden{% endunless %}">
      <a href="{{ results_url }}" class="active-facets__button-remove">
        <span>{{ 'products.facets.clear_all' | t }}</span>
        <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
      </a>
    </facet-remove>
  {%- endif -%}
  </div>
  <menu-drawer class="mobile-facets__wrapper medium--hide large-up--hide" data-breakpoint="mobile">
    <details class="mobile-facets__disclosure disclosure-has-popup">
      <summary class="mobile-facets__open-wrapper background-modal">
        <span class="mobile-facets__open">
          <span class="mobile-facets__open-label button-label medium-hide large-up-hide">
            {%- if enable_filtering and enable_sorting -%}
              <i class="{{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i> {{ 'products.facets.filter_and_sort' | t }}
            {%- elsif enable_filtering -%}
              <i class="{{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i> {{ 'products.facets.filter_button' | t }}
            {%- elsif enable_sorting -%}
              <i class="{{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i> {{ 'products.facets.sort_button' | t }}
            {%- endif -%}
          </span>
        </span>
        <span tabindex="0" class="mobile-facets__close mobile-facets__close--no-js btn btn--style-2 modal__close-button btn-close-modal-text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
          {{ 'accessibility.close' | t }}
        </span>
      </summary>
      <facet-filters-form>
        <form id="FacetFiltersFormMobile" class="mobile-facets">
          <div class="mobile-facets__inner">
            <div class="mobile-facets__main has-submenu">
              {%- if enable_sorting -%}
                {%- assign sort_by = results.sort_by | default: results.default_sort_by -%}
                <details id="Details-Mobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__details facets__filters__details js-filter" data-index="mobile-{{ forloop.index }}">
                  <summary class="mobile-facets__summary focus-inset background-modal">
                    <div>
                      <span>{{ 'products.facets.sort_by_label' | t }}</span>
                      <span class="mobile-facets__arrow">
                        <i class="icon icon-plus {{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i>
                        <i class="icon icon-minus {{ icon_style }} fa-minus" style="--fa-secondary-opacity: 1;"></i>
                      </span>
                    </div>
                  </summary>
                  <div id="FacetMobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__submenu background-modal">
                    <ul class="mobile-facets__list list-unstyled" role="list">
                      {%- for option in results.sort_options -%}
                        <li class="list-menu__item facets__item">
                          <label for="Sort-{{ 'products.facets.sort_by_label' | t }}-mobile-{{ forloop.index }}" class="mobile-facets__label{% if option.value == sort_by %} mobile-facets__label--checked{% endif %}">
                            <input
                              class="mobile-facets__checkbox"
                              type="radio"
                              name="sort_by"
                              value="{{ option.value | escape }}"
                              data-sort-name="{{ option.name | escape }}"
                              id="Sort-{{ 'products.facets.sort_by_label' | t }}-mobile-{{ forloop.index }}"
                              {% if option.value == sort_by %}checked{% endif %}>
                            <span class="mobile-facets__highlight"></span>
                            <span class="mobile-facets__label-text" aria-hidden="true">{{ option.name | escape }}</span>
                            <span class="input-check-mark"><i class="icon icon-check {{ icon_style }} fa-check"></i></span>
                            <span class="input-loading btn__loader">
                              <div class="spinner">
                                <div class="bounce1"></div>
                                <div class="bounce2"></div>
                                <div class="bounce3"></div>
                              </div>
                            </span>
                            <span class="visually-hidden">{{ option.name | escape }}</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </details>
              {%- endif -%}

              {%- if enable_filtering -%}
                <h2 class="mobile-facets__heading facets__heading">
                  {{ 'products.facets.filter_by_label' | t }}
                </h2>
                {%- for filter in results.filters -%}
                  {% case filter.type %}
                  {% when 'boolean' or 'list' %}
                    <details id="Details-Mobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__details js-filter" data-index="mobile-{{ forloop.index }}">
                      <summary class="mobile-facets__summary focus-inset background-modal">
                        <div>
                          <span>{{ filter.label | escape }}</span>
                          <span class="mobile-facets__arrow">
                            <i class="icon icon-plus {{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i>
                            <i class="icon icon-minus {{ icon_style }} fa-minus" style="--fa-secondary-opacity: 1;"></i>
                          </span>
                        </div>
                      </summary>
                      <div id="FacetMobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__submenu background-modal">
                        <ul class="mobile-facets__list list-unstyled" role="list">
                          {%- for value in filter.values -%}
                            <li class="mobile-facets__item list-menu__item">
                              <label for="Filter-{{ filter.label | escape }}-mobile-{{ forloop.index }}" class="mobile-facets__label{% if value.count == 0 and value.active == false %} mobile-facets__label--disabled{% endif %}{% if value.active %} mobile-facets__label--checked{% endif %}">
                                <input class="mobile-facets__checkbox" type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" id="Filter-{{ filter.label | escape }}-mobile-{{ forloop.index }}"
                                  {% if value.active %}checked{% endif %}
                                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                >
                                <span class="mobile-facets__highlight"></span>
                                <span class="mobile-facets__label-text" aria-hidden="true">{{ value.label | escape }} ({{ value.count }})</span>
                                <span class="input-check-mark"><i class="icon icon-check {{ icon_style }} fa-check"></i></span>
                                <span class="input-loading btn__loader">
                                  <div class="spinner">
                                    <div class="bounce1"></div>
                                    <div class="bounce2"></div>
                                    <div class="bounce3"></div>
                                  </div>
                                </span>
                                <span class="visually-hidden">{{ value.label | escape }} ({% if value.count == '1' %}{{ 'products.facets.product_count_simple.one' | t: count: value.count }}{% else %}{{ 'products.facets.product_count_simple.other' | t: count: value.count }}{% endif %})</span>
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </details>
                  {% when 'price_range' %}
                    <details id="Details-Mobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__details js-filter" data-index="mobile-{{ forloop.index }}">
                      <summary class="mobile-facets__summary focus-inset background-modal">
                        <div>
                          <span>{{ filter.label | escape }}</span>
                          <span class="mobile-facets__arrow">
                            <i class="icon icon-plus {{ icon_style }} fa-plus" style="--fa-secondary-opacity: 1;"></i>
                            <i class="icon icon-minus {{ icon_style }} fa-minus" style="--fa-secondary-opacity: 1;"></i>
                          </span>
                        </div>
                      </summary>
                      <div id="FacetMobile-{{ forloop.index }}-{{ section.id }}" class="mobile-facets__submenu background-modal">
                        {%- assign max_price_amount = filter.range_max | money | strip_html | escape -%}
                        <price-range class="facets__price">
                          <div class="field-wrapper">
                            <span class="field-currency">{{ cart.currency.symbol }}</span>
                            <input class="field-wrapper__input input--dark filter__price__input"
                              name="{{ filter.min_value.param_name }}"
                              id="Mobile-Filter-{{ filter.label | escape }}-GTE"
                              {%- if filter.min_value.value -%}
                                {%- if uses_comma_decimals -%}value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                              {%- endif -%}
                              type="number"
                              placeholder="0"
                              min="0"
                              inputmode="decimal"
                              {%- if uses_comma_decimals -%}max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"{% endif %}
                            >
                            <label class="field-wrapper__label" for="Mobile-Filter-{{ filter.label | escape }}-GTE">
                              <span class="field-wrapper__label-name">{{ 'products.facets.from' | t }}</span>
                            </label>
                          </div>

                          <div class="field-wrapper">
                            <span class="field-currency">{{ cart.currency.symbol }}</span>
                            <input class="field-wrapper__input filter__price__input"
                              name="{{ filter.max_value.param_name }}"
                              id="Mobile-Filter-{{ filter.label | escape }}-LTE"
                              {%- if filter.max_value.value -%}
                                {%- if uses_comma_decimals -%}value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"{%- else -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                              {%- endif -%}
                              type="number"
                              min="0"
                              inputmode="decimal"
                              {%- if uses_comma_decimals -%}
                                placeholder="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                                max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                              {%- else -%}
                                placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                              {% endif %}
                            >
                            <label class="field-wrapper__label" for="Mobile-Filter-{{ filter.label | escape }}-LTE">
                              <span class="field-wrapper__label-name">{{ 'products.facets.to' | t }}</span>
                            </label>
                          </div>
                          <p class="requirement-form">
                            {{ "products.facets.max_price" | t: price: max_price_amount }}
                          </p>
                        </price-range>
                      </div>
                    </details>
                  {% endcase %}
                {%- endfor -%}
              {%- endif -%}

              <div class="mobile-facets__footer ">
                <facet-remove class="mobile-facets__clear-wrapper">
                  <a href="{{ results_url }}" class="mobile-facets__clear btn btn--secondary">{{ 'products.facets.clear' | t }}</a>
                </facet-remove>
                <button type="button" class="no-js-hidden btn btn--light" onclick="this.closest('.mobile-facets__wrapper').querySelector('summary').click()">{{ 'products.facets.apply' | t }}</button>
                <noscript><button class="btn btn--light">{{ 'products.facets.apply' | t }}</button></noscript>
              </div>
            </div>

            {% if results.current_vendor or results.current_type %}
              <input type="hidden" name="q" value="{{ results.current_vendor }}{{ results.current_type }}">
            {% endif %}

            {%- if results.terms -%}
              <input type="hidden" name="q" value="{{ results.terms | escape }}">
              <input name="options[prefix]" type="hidden" value="last">
            {%- endif -%}
          </div>
        </form>
      </facet-filters-form>
    </details>
  </menu-drawer>

  <div class="active-facets active-facets-mobile medium--hide large-up--hide">
    {%- for filter in results.filters -%}
      {%- for value in filter.active_values -%}
        <facet-remove>
          <a href="{{ value.url_to_remove }}" class="active-facets__button active-facets__button--light">
            <span class="active-facets__button-inner background-modal">
              {{ value.label | escape }}
              <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
              <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
            </span>
          </a>
        </facet-remove>
      {%- endfor -%}

      {%- if filter.type == "price_range" -%}
        {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
          <facet-remove>
            <a href="{{ filter.url_to_remove }}" class="active-facets__button active-facets__button--light">
              <span class="active-facets__button-inner background-modal">
                {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}-{%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                <i class="icon icon-close {{ icon_style }} fa-xmark-large" style="--fa-secondary-opacity: 1;"></i>
                <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
              </span>
            </a>
          </facet-remove>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
