{% comment %}
  Renders gift card recipient form.
  Accepts:
  - product: {Object} product object.
  - form: {Object} the product form object.
  - section: {Object} section to which this snippet belongs.

  Usage:
  {% render 'gift-card-recipient-form', product: product, form: form, section: section %}
{% endcomment %}

{% assign icon_style = settings.icons_style %}

<div class="customer">
  {%- assign gift_card_recipient_control_flag = 'properties[__shopify_send_gift_card_to_recipient]' -%}
  <script src="{{ 'recipient-form.js' | asset_url }}" defer="defer"></script>
  <recipient-form
    class="recipient-form"
    data-section-id="{{ section.id }}"
    data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
  >
    <input
      id="Recipient-Checkbox-{{ section.id }}"
      type="checkbox"
      name="{{ gift_card_recipient_control_flag }}"
      disabled
    >
    <label class="recipient-checkbox" for="Recipient-Checkbox-{{ section.id }}">
      <span class="input-check-mark">
        <i class="icon-check {{ icon_style }} fa-check"></i>
      </span>
      {{ 'recipient.form.checkbox' | t }}
    </label>
    <div class="recipient-fields">
      <div class="recipient-fields__field">
        <div class="field-wrapper">
          <input
            class="field-wrapper__input"
            id="Recipient-email-{{ section.id }}"
            type="email"
            placeholder="{{ 'recipient.form.email' | t }}"
            name="properties[Recipient email]"
            value="{{ form.email }}"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-email-error-{{ section.id }}"
            {% endif %}
          >
          <label class="field-wrapper__label" for="Recipient-email-{{ section.id }}">
            <span class="field-wrapper__label-name recipient-email-label required">{{ 'recipient.form.email_label' | t }}</span>
            <span class="field-wrapper__label-name recipient-email-label optional">
              {{ 'recipient.form.email_label' | t }}
            </span>
          </label>
          <span class="field-wrapper__icon-error hide" aria-invalid="true">
            <i class="icon icon-error {{ icon_style }} fa-circle-exclamation"></i>
          </span>
        </div>
        <span id="RecipientForm-email-error-{{ section.id }}" class="form__message input-error-message{% unless  form.errors contains 'email' %} hide{% endunless %}">
          <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
          <span class="error-message">
            {%- if  form.errors contains 'email' -%}
              {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
            {%- endif -%}
          </span>
        </span>
      </div>

      <div class="recipient-fields__field">
        <div class="field-wrapper">
          <input
            class="field-wrapper__input"
            autocomplete="name"
            type="text"
            id="Recipient-name-{{ section.id }}"
            name="properties[Recipient name]"
            placeholder="{{ 'recipient.form.name' | t }}"
            value="{{ form.name }}"
            {% if form.errors contains 'name' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-name-error-{{ section.id }}"
            {% endif %}
          >
          <label class="field-wrapper__label" for="Recipient-name-{{ section.id }}">
            <span class="field-wrapper__label-name">{{- 'recipient.form.name_label' | t -}}</span>
          </label>
        </div>

        <span id="RecipientForm-name-error-{{ section.id }}" class="form__message input-error-message{% unless  form.errors contains 'name' %} hide{% endunless %}">
          <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
          <span class="error-message">
            {%- if form.errors contains 'name' -%}
              {{ form.errors.translated_fields.name | capitalize }}
              {{ form.errors.messages.name }}.
            {%- endif -%}
          </span>
        </span>
      </div>

      <div class="recipient-fields__field">
        {%- assign max_chars_message = 200 -%}
        {%- assign max_chars_message_rendered = 'recipient.form.max_characters' | t: max_chars: max_chars_message -%}
        {%- assign message_label_rendered = 'recipient.form.message_label' | t -%}
        <div class="field-wrapper">
          <textarea
            rows="10"
            id="Recipient-message-{{ section.id }}"
            class="text-area field-wrapper__input requirement-input"
            name="properties[Message]"
            maxlength="{{ max_chars_message }}"
            placeholder="{{ 'recipient.form.message' | t }}"
            aria-label="{{ message_label_rendered }} {{ max_chars_message_rendered }}"
            {% if form.errors contains 'message' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-message-error-{{ section.id }}"
            {% endif %}
          >{{ form.message }}</textarea>
          <label class="field-wrapper__label" for="Recipient-message-{{ section.id }}">
            <span class="field-wrapper__label-name">{{ message_label_rendered }}<span>
          </label>
        </div>

        <p class="requirement-form">
          <span>{{ max_chars_message_rendered }}</span>
        </p>

        <span id="RecipientForm-message-error-{{ section.id }}" class="form__message input-error-message{% unless  form.errors contains 'message' %} hide{% endunless %}">
          <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
          <span class="error-message">
            {%- if form.errors contains 'message' -%}
              {{ form.errors.translated_fields.message | capitalize }}
              {{ form.errors.messages.message }}.
            {%- endif -%}
          </span>
        </span>
      </div>
    </div>
    <input
      type="hidden"
      name="{{ gift_card_recipient_control_flag }}"
      value="if_present"
      id="Recipient-Control-{{ section.id }}"
    >
  </recipient-form>
</div>
